{% doc %}
  @prompt
    floating email collector i needed that opens after 50% scroll of the page 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-email-popup-{{ ai_gen_id }} {
    position: fixed;
    bottom: 20px;
    right: 20px;
    width: 90%;
    max-width: 400px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    padding: 30px;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transform: translateY(20px);
    transition: opacity 0.4s ease, visibility 0.4s ease, transform 0.4s ease;
    display: block;
  }

  .ai-email-popup-{{ ai_gen_id }}.ai-email-popup-visible-{{ ai_gen_id }} {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .ai-email-popup-{{ ai_gen_id }}.ai-email-popup-hidden-{{ ai_gen_id }} {
    opacity: 0;
    visibility: hidden;
    transform: translateY(20px);
  }

  .ai-email-popup-close-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    right: 12px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }

  .ai-email-popup-close-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-email-popup-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-email-popup-heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
  }

  .ai-email-popup-subtext-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
    margin: 0;
  }

  .ai-email-popup-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-email-popup-input-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
  }

  .ai-email-popup-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.input_text_color }};
    opacity: 0.6;
  }

  .ai-email-popup-button-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-email-popup-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-email-popup-success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    font-size: 14px;
    margin-top: 8px;
  }

  .ai-email-popup-error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    font-size: 14px;
    margin-top: 8px;
  }

  @media screen and (max-width: 749px) {
    .ai-email-popup-{{ ai_gen_id }} {
      bottom: 16px;
      right: 16px;
      left: 16px;
      width: auto;
      max-width: none;
      padding: 24px;
    }

    .ai-email-popup-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.85);
    }

    .ai-email-popup-subtext-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }
  }
{% endstyle %}

<email-popup-{{ ai_gen_id }}
  class="ai-email-popup-{{ ai_gen_id }}"
  data-scroll-threshold="{{ block.settings.scroll_threshold }}"
  {{ block.shopify_attributes }}
>
  <button
    class="ai-email-popup-close-{{ ai_gen_id }}"
    aria-label="Close popup"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <div class="ai-email-popup-content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h3 class="ai-email-popup-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
    {% endif %}

    {% if block.settings.subtext != blank %}
      <p class="ai-email-popup-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
    {% endif %}

    {%- form 'contact', class: 'ai-email-popup-form-' | append: ai_gen_id -%}
      <input
        type="hidden"
        name="contact[tags]"
        value="newsletter"
      >
      <input
        type="email"
        name="contact[email]"
        class="ai-email-popup-input-{{ ai_gen_id }}"
        value="{{ form.email }}"
        aria-required="true"
        autocorrect="off"
        autocapitalize="off"
        autocomplete="email"
        {% if form.errors %}
          aria-invalid="true"
          aria-describedby="ai-email-popup-error-{{ ai_gen_id }}"
        {% endif %}
        {% if form.posted_successfully? %}
          aria-describedby="ai-email-popup-success-{{ ai_gen_id }}"
        {% endif %}
        placeholder="{{ block.settings.email_placeholder }}"
        required
      >
      <button
        type="submit"
        class="ai-email-popup-button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_label }}
      </button>

      {%- if form.errors -%}
        <div
          id="ai-email-popup-error-{{ ai_gen_id }}"
          class="ai-email-popup-error-{{ ai_gen_id }}"
        >
          <span>{{ form.errors.messages.email }}</span>
        </div>
      {%- endif -%}

      {%- if form.posted_successfully? -%}
        <div
          id="ai-email-popup-success-{{ ai_gen_id }}"
          class="ai-email-popup-success-{{ ai_gen_id }}"
        >
          <span>{{ block.settings.success_message }}</span>
        </div>
      {%- endif -%}
    {%- endform -%}
  </div>
</email-popup-{{ ai_gen_id }}>

<script>
  (function() {
    class EmailPopup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.scrollThreshold = parseFloat(this.dataset.scrollThreshold) || 50;
        this.hasShown = false;
        this.isDismissed = false;
        this.storageKey = 'emailPopupDismissed{{ ai_gen_id }}';
      }

      connectedCallback() {
        this.closeButton = this.querySelector('.ai-email-popup-close-{{ ai_gen_id }}');
        this.form = this.querySelector('form');
        
        if (sessionStorage.getItem(this.storageKey)) {
          this.isDismissed = true;
          return;
        }

        this.setupEventListeners();
        this.checkScroll();
      }

      setupEventListeners() {
        window.addEventListener('scroll', this.handleScroll.bind(this));
        
        if (this.closeButton) {
          this.closeButton.addEventListener('click', this.closePopup.bind(this));
        }

        if (this.form) {
          this.form.addEventListener('submit', this.handleSubmit.bind(this));
        }
      }

      handleScroll() {
        if (this.isDismissed || this.hasShown) return;
        this.checkScroll();
      }

      checkScroll() {
        const scrollPercent = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
        
        if (scrollPercent >= this.scrollThreshold && !this.hasShown && !this.isDismissed) {
          this.showPopup();
        }
      }

      showPopup() {
        this.hasShown = true;
        this.classList.add('ai-email-popup-visible-{{ ai_gen_id }}');
        this.classList.remove('ai-email-popup-hidden-{{ ai_gen_id }}');
      }

      closePopup() {
        this.classList.remove('ai-email-popup-visible-{{ ai_gen_id }}');
        this.classList.add('ai-email-popup-hidden-{{ ai_gen_id }}');
        this.isDismissed = true;
        sessionStorage.setItem(this.storageKey, 'true');
      }

      handleSubmit() {
        setTimeout(() => {
          const successMessage = this.querySelector('.ai-email-popup-success-{{ ai_gen_id }}');
          if (successMessage) {
            setTimeout(() => {
              this.closePopup();
            }, 2000);
          }
        }, 100);
      }
    }

    customElements.define('email-popup-{{ ai_gen_id }}', EmailPopup{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Floating email collector",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Join our newsletter"
    },
    {
      "type": "inline_richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "Get exclusive offers and updates delivered to your inbox."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks for subscribing!"
    },
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "range",
      "id": "scroll_threshold",
      "label": "Show after scroll",
      "min": 10,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Input field"
    },
    {
      "type": "color",
      "id": "input_background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "input_text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "Border color",
      "default": "#e6e6e6"
    },
    {
      "type": "range",
      "id": "input_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 16,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Background color",
      "default": "#a42325"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Hover background color",
      "default": "#780406"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 16,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Messages"
    },
    {
      "type": "color",
      "id": "success_color",
      "label": "Success color",
      "default": "#008060"
    },
    {
      "type": "color",
      "id": "error_color",
      "label": "Error color",
      "default": "#D82C0D"
    }
  ],
  "presets": [
    {
      "name": "Floating email collector"
    }
  ]
}
{% endschema %}
