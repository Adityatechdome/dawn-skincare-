<section class="luxury-footer">
  <div class="footer-content">
    <div class="footer-column">
      <h4>{{ section.settings.brand_name }}</h4>
      <p>{{ section.settings.brand_description }}</p>
    </div>

    <div class="footer-column">
      <h5>{{ section.settings.shop_heading }}</h5>
      <ul>
        <li><a href="{{ section.settings.shop_link_1_url }}">{{ section.settings.shop_link_1_text }}</a></li>
        <li><a href="{{ section.settings.shop_link_2_url }}">{{ section.settings.shop_link_2_text }}</a></li>
        <li><a href="{{ section.settings.shop_link_3_url }}">{{ section.settings.shop_link_3_text }}</a></li>
        <li><a href="{{ section.settings.shop_link_4_url }}">{{ section.settings.shop_link_4_text }}</a></li>
      </ul>
    </div>

    <div class="footer-column">
      <h5>{{ section.settings.atelier_heading }}</h5>
      <ul>
        <li><a href="{{ section.settings.atelier_link_1_url }}">{{ section.settings.atelier_link_1_text }}</a></li>
        <li><a href="{{ section.settings.atelier_link_2_url }}">{{ section.settings.atelier_link_2_text }}</a></li>
        <li><a href="{{ section.settings.atelier_link_3_url }}">{{ section.settings.atelier_link_3_text }}</a></li>
      </ul>
    </div>

    <div class="footer-column">
      <h5>{{ section.settings.court_heading }}</h5>
      <ul>
        <li><a href="{{ section.settings.court_link_1_url }}">{{ section.settings.court_link_1_text }}</a></li>
        <li><a href="{{ section.settings.court_link_2_url }}">{{ section.settings.court_link_2_text }}</a></li>
        <li><a href="{{ section.settings.court_link_3_url }}">{{ section.settings.court_link_3_text }}</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p>{{ section.settings.copyright_text }}</p>
    <div class="footer-links">
      <a href="{{ section.settings.privacy_link }}">{{ section.settings.privacy_text }}</a>
      <span>·</span>
      <a href="{{ section.settings.terms_link }}">{{ section.settings.terms_text }}</a>
    </div>
  </div>
</section>

<style>
  .luxury-footer {
    background: #2A2438;
    color: #D9BA82;
    padding: 80px 56px 40px;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 60px;
    max-width: 1320px;
    margin: 0 auto 60px;
  }

  .footer-column h4 {
    font-family: "Italiana", serif;
    font-size: 24px;
    color: #F8F1E7;
    margin: 0 0 20px 0;
    letter-spacing: 0.08em;
  }

  .footer-column h5 {
    font-family: "Inter", sans-serif;
    font-size: 12px;
    color: #D9BA82;
    margin: 0 0 16px 0;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .footer-column p {
    font-family: "Cormorant Garamond", serif;
    font-size: 16px;
    color: #B8A89F;
    line-height: 1.6;
    margin: 0;
  }

  .footer-column ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-column li {
    margin-bottom: 12px;
  }

  .footer-column a {
    font-family: "Cormorant Garamond", serif;
    font-size: 16px;
    color: #B8A89F;
    transition: color 0.3s ease;
  }

  .footer-column a:hover {
    color: #D9BA82;
  }

  .footer-bottom {
    border-top: 1px solid rgba(217, 186, 130, 0.2);
    padding-top: 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1320px;
    margin: 0 auto;
  }

  .footer-bottom p {
    font-family: "Inter", sans-serif;
    font-size: 12px;
    color: #8C7A8F;
    margin: 0;
  }

  .footer-links {
    display: flex;
    gap: 12px;
    font-size: 12px;
  }

  .footer-links a {
    color: #8C7A8F;
    transition: color 0.3s ease;
  }

  .footer-links a:hover {
    color: #D9BA82;
  }

  .footer-links span {
    color: #8C7A8F;
  }

  @media (max-width: 1000px) {
    .footer-content {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 768px) {
    .luxury-footer {
      padding: 40px 20px 30px;
    }

    .footer-content {
      grid-template-columns: 1fr;
      gap: 30px;
      margin-bottom: 40px;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }

    .footer-column h4 {
      font-size: 20px;
    }

    .footer-column p {
      font-size: 14px;
    }

    .footer-column a {
      font-size: 14px;
    }
  }
</style>

