<section class="luxury-marquee">
  <div class="marquee-wrapper">
    <div class="marquee-content">
      <span>{{ section.settings.marquee_text }}</span>
      <span>{{ section.settings.marquee_text }}</span>
      <span>{{ section.settings.marquee_text }}</span>
    </div>
  </div>
</section>

<style>
  .luxury-marquee {
    background: #3D3158;
    padding: 30px 0;
    overflow: hidden;
  }

  .marquee-wrapper {
    position: relative;
    width: 100%;
  }

  .marquee-content {
    display: flex;
    gap: 40px;
    animation: marquee 20s linear infinite;
    white-space: nowrap;
    font-family: "Cormorant Garamond", serif;
    font-size: 32px;
    color: #D9BA82;
    letter-spacing: 0.05em;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }

  @media (max-width: 768px) {
    .marquee-content {
      font-size: 20px;
      gap: 20px;
    }
  }
</style>

{% schema %}
{
  "name": "Luxury Marquee",
  "settings": [
    {
      "type": "text",
      "id": "marquee_text",
      "label": "Marquee Text",
      "default": "✨ Royal Elegance Meets Modern Skincare ✨"
    }
  ]
}
{% endschema %}
