{% schema %}
  {
    "name": "Header Navigation",
    "tag": "section",
    "class": "header-navigation",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      }, {
        "type": "text",
        "id": "brand_name",
        "label": "Fallback Brand Name",
        "default": "DAWN"
      }, {
        "type": "link_list",
        "id": "menu",
        "label": "Navigation Menu",
        "default": "main-menu"
      }
    ],
    "presets": [
      {
        "name": "Header Navigation",
        "category": "Header"
      }
    ]
  }
{% endschema %}

<header class="site-header">
  <div class="header-container">
    <div class="d-mobile">
      <button
        class="hamburger"
        aria-label="Toggle menu"
        onclick="document.querySelector('.drawer').classList.toggle('open')">
        ☰
      </button>
    </div>

    <div class="header-left">
      <a href="/" class="brand-logo">
        {% if section.settings.logo %}
          {{
            section.settings.logo
            | image_url: width: 176
            | image_tag:
              alt: 'Logo',
              loading: 'eager',
              widths: '70, 88, 140, 176',
              sizes: '(max-width: 900px) 50px, 70px',
              width: section.settings.logo.width,
              height: section.settings.logo.height
          }}
        {% else %}
          {{ section.settings.brand_name }}
        {% endif %}
      </a>
    </div>

    <nav class="header-nav desktop-nav">
      <ul class="nav-menu">
        {% for link in linklists[section.settings.menu].links %}
          <li>
            <a href="{{ link.url }}">{{ link.title }}</a>
          </li>
        {% endfor %}
      </ul>
    </nav>

    <div class="header-right">
      <a
        href="/account"
        class="icon user-icon"
        aria-label="Account">
        <img
          src="https://cdn.shopify.com/s/files/1/0949/2319/4641/files/user_1.png?v=1767806850&width=35&format=webp"
          srcset="https://cdn.shopify.com/s/files/1/0949/2319/4641/files/user_1.png?v=1767806850&width=35&format=webp 1x, https://cdn.shopify.com/s/files/1/0949/2319/4641/files/user_1.png?v=1767806850&width=70&format=webp 2x"
          alt="Account"
          loading="lazy"
          decoding="async"
          width="30"
          height="30"
        >
      </a>
      {%- comment -%} Cart Icon Trigger - The drawer itself is in custom-cart-drawer section {%- endcomment -%}
      <button
        class="button header-actions__action button-unstyled icon cart-icon"
        onclick="document.querySelector('cart-drawer-component dialog')?.showModal()"
        aria-haspopup="dialog"
        aria-label="Open cart"
        data-testid="cart-drawer-trigger"
      >
        <img
          src="https://cdn.shopify.com/s/files/1/0949/2319/4641/files/shopping-cart.png?v=1767806122&width=35&format=webp"
          srcset="https://cdn.shopify.com/s/files/1/0949/2319/4641/files/shopping-cart.png?v=1767806122&width=35&format=webp 1x, https://cdn.shopify.com/s/files/1/0949/2319/4641/files/shopping-cart.png?v=1767806122&width=70&format=webp 2x"
          alt="Cart"
          loading="lazy"
          decoding="async"
          width="35"
          height="35"
        >
      </button>
    </div>
  </div>
</header>
<!-- 🔹 Primary Drawer (Navigation) -->
<div class="header drawer">
  <button
    class="drawer-close"
    aria-label="Close menu"
    onclick="document.querySelector('.drawer').classList.remove('open')">
    &times;
  </button>
  <ul class="nav-menu">
    {% for link in linklists[section.settings.menu].links %}
      <li>
        <a href="{{ link.url }}" onclick="document.querySelector('.drawer').classList.remove('open')">
          {{ link.title }}
        </a>
      </li>
    {% endfor %}
  </ul>
</div>
<style>
  body {
    padding: 86px 0 0;
    background: #EEEAE1;
  }
  .header-navigation {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .site-header {
    border-radius: 0;
    background: #1c1b19;
    padding: 3px 40px;
    max-width: 100%;
    margin: 0;
    width: 100%;
    position: fixed;
    top: 0;
    left: 0;
    z-index: 100;
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 50px;
    height: 50px;
  }

  .brand-logo {
    display: flex;
    align-items: center;
    max-width: 70px;
  }

  .brand-logo img {
    width: 100%;
    height: auto;
    display: block;
  }

  .nav-menu {
    display: flex;
    gap: 60px;
    padding: 0;
    list-style: none;
    margin: 0;
  }

  .nav-menu a {
    text-decoration: none;
    color: #eeeae1;
    font-family: Inter;
    font-size: 18px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    transition: opacity 0.3s ease;
  }

  .nav-menu a:hover {
    opacity: 0.6;
  }

  .header-right {
    display: flex;
    gap: 40px;
  }

  .header-right .icon {
    display: inline-block;
    width: 25px;
    height: 25px;
  }

  .header-right .icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .header-right .button-unstyled {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .hamburger {
    display: none;
    font-size: 28px;
    background: none;
    border: none;
    color: #eeeae1;
    cursor: pointer;
  }

  .d-mobile {
    display: none;
  }

  @media (max-width: 900px) {
    body {
      padding-top: 56px;
    }

    .site-header {
      padding: 3px 20px;
      max-width: 100%;
    }

    .header-container {
      min-height: 50px;
    }

    .brand-logo {
      width: 50px;
      height: auto;
      display: flex;
      align-items: center;
      line-height: 0;
    }

    .header-right {
      gap: 20px;
    }

    .header-right .icon {
      width: 20px;
      height: 20px;
    }

    .header-right .icon img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .d-mobile {
      display: block;
    }

    .hamburger {
      display: block;
    }

    .desktop-nav {
      display: none;
    }

    .drawer-primary .nav-menu {
      flex-direction: column;
      gap: 30px;
      margin: 0;
      padding: 0;
      text-align: left;
    }

    .drawer-primary .nav-menu a {
      font-size: 20px;
      padding: 10px 0;
      display: block;
    }

    .drawer-secondary .extra-content {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
  }
  .header.drawer {
    position: fixed;
    top: 0;
    left: 0;
    right: unset;
    bottom: unset;
    width: 80%;
    height: 100vh;
    background-color: #1c1b19;
    color: #eeeae1;
    transition: transform 0.4s ease;
    padding: 40px 30px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
  }

  .drawer-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 2rem;
    cursor: pointer;
    line-height: 1;
    color: #fff;
    transition: color 0.2s ease;
  }

  .drawer-close:hover {
    color: #ccc;
  }

  /* When open — slides in */
  .drawer.open {
    transform: translate(0%, 0px);
  }

  .drawer .nav-menu {
    display: flex;
    flex-direction: column;
    gap: 30px;
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
  }

  .drawer .nav-menu a {
    font-size: 20px;
    color: #eeeae1;
    text-decoration: none;
    display: block;
    padding: 10px 0;
  }

  .drawer .nav-menu a:hover {
    opacity: 0.7;
  }

  @media (min-width: 1001px) {
    .drawer {
      display: none;
      /* hide on desktop */
    }
  }
</style>
