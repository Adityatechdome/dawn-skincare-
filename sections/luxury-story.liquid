<section id="story-{{ section.id }}" class="dawn-story">

  <div class="story-inner">

    <!-- HEADER -->

    <div class="story-eyebrow reveal">
      <span>{{ section.settings.eyebrow }}</span>
    </div>

    <!-- LETTER -->

    <div class="story-letter">

      <!-- TITLE -->

      <h3 class="story-title reveal">
        {{ section.settings.title_line_1 }}

        <em>
          {{ section.settings.title_line_2 }}
        </em>
      </h3>

      <!-- DATE -->

      <div class="story-dateline reveal">
        {{ section.settings.dateline }}
      </div>

      <!-- BODY -->

      <div class="story-body">

        <p class="reveal">
          {{ section.settings.paragraph_1 }}
        </p>

        <p class="reveal">
          {{ section.settings.paragraph_2 }}
        </p>

        <p class="reveal">
          {{ section.settings.paragraph_3 }}
        </p>

      </div>

      <!-- SIGNATURE -->

      <div class="story-signature reveal">
        {{ section.settings.signature }}
      </div>

    </div>

  </div>

</section>

<style>

#story-{{ section.id }}{
  position: relative;

  width: 100vw;
  max-width: 100vw;

  left: 50%;
  right: 50%;

  margin-left: -50vw;
  margin-right: -50vw;

  overflow: hidden;

  background:
    linear-gradient(
      180deg,
      #F8F1E7 0%,
      #EFE4D2 100%
    );

  padding: 140px 56px;
}

#story-{{ section.id }} *{
  box-sizing: border-box;
}

.story-inner{
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
}

/* EYEBROW */

.story-eyebrow{
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;

  margin-bottom: 80px;
}

.story-eyebrow::before,
.story-eyebrow::after{
  content: "";

  width: 36px;
  height: 1px;

  background: #B8945A;

  opacity: 0.6;
}

.story-eyebrow span{
  font-family: "Inter", sans-serif;
  font-size: 11px;
  font-weight: 500;

  letter-spacing: 0.32em;
  text-transform: uppercase;

  color: #8C6F3F;
}

/* LETTER */

.story-letter{
  position: relative;

  max-width: 720px;

  margin: 0 auto;

  padding: 80px 80px 64px;

  border: 1px solid rgba(184,148,90,0.25);

  box-shadow:
    0 60px 100px -50px rgba(91,74,122,0.30);

  background:
    radial-gradient(
      ellipse at 50% 0%,
      rgba(255,255,255,0.5),
      transparent 60%
    ),
    #FBF6EE;
}

/* FILIGREE */

.story-letter::before,
.story-letter::after{
  content: "";

  position: absolute;

  width: 64px;
  height: 64px;

  background-repeat: no-repeat;
  background-size: contain;

  opacity: 0.9;

  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64' fill='none' stroke='%23B8945A' stroke-width='1'><path d='M2 2 Q 18 18 2 32 M 2 2 Q 18 18 32 2 M 14 14 Q 22 14 22 22 M 14 14 Q 22 14 14 22'/></svg>");
}

.story-letter::before{
  top: 12px;
  left: 12px;
}

.story-letter::after{
  bottom: 12px;
  right: 12px;

  transform: rotate(180deg);
}

/* TITLE */

.story-title{
  margin: 0 0 12px;

  text-align: center;

  font-family: "Italiana", serif;
  font-size: clamp(36px, 5vw, 64px);
  line-height: 1;
  font-weight: 400;

  color: #2A2438;
}

.story-title em{
  display: block;

  margin-top: 6px;

  font-family: "Pinyon Script", cursive;
  font-style: normal;
  font-size: 1.1em;

  color: #8C6F3F;

  text-transform: none !important;
}

/* DATE */

.story-dateline{
  margin-bottom: 40px;

  text-align: center;

  font-family: "JetBrains Mono", monospace;
  font-size: 10px;

  letter-spacing: 0.3em;
  text-transform: uppercase;

  color: #8C6F3F;
}

/* BODY */

.story-body p{
  margin: 0 0 22px;

  font-family: "Cormorant Garamond", serif;
  font-size: 19px;
  line-height: 1.65;

  color: #2A2438;

  text-wrap: pretty;
}

/* DROP CAP */

.story-body p:first-of-type::first-letter{
  float: left;

  margin: 6px 10px 0 0;

  font-family: "Italiana", serif;
  font-size: 4em;
  line-height: 0.85;

  color: #8C6F3F;
}

.story-body p:not(:first-of-type)::first-letter{
  float: none;

  margin: 0;

  font-size: 1em;

  color: inherit;
}

/* SIGNATURE */

.story-signature{
  margin-top: 36px;

  text-align: right;

  font-family: "Pinyon Script", cursive;
  font-size: 36px;

  color: #5B4A7A;

  text-transform: none !important;
}

/* REVEAL */

.reveal{
  opacity: 0;

  transform: translateY(40px);

  animation:
    storyReveal 0.9s cubic-bezier(0.2,0.8,0.2,1) forwards;
}

.story-title{
  animation-delay: 0.1s;
}

.story-dateline{
  animation-delay: 0.22s;
}

.story-body p:nth-child(1){
  animation-delay: 0.34s;
}

.story-body p:nth-child(2){
  animation-delay: 0.46s;
}

.story-body p:nth-child(3){
  animation-delay: 0.58s;
}

.story-signature{
  animation-delay: 0.7s;
}

@keyframes storyReveal{
  to{
    opacity: 1;
    transform: translateY(0);
  }
}

/* RESPONSIVE */

@media screen and (max-width: 999px){

  .story-letter{
    padding: 64px 56px;
  }

  .story-letter::before,
  .story-letter::after{
    width: 48px;
    height: 48px;
  }

}

@media screen and (max-width: 700px){

  #story-{{ section.id }}{
    padding: 90px 24px;
  }

  .story-letter{
    padding: 56px 32px;
  }

  .story-letter::before,
  .story-letter::after{
    display: none;
  }

  .story-body p:first-of-type::first-letter{
    font-size: 3.4em;
  }

  .story-signature{
    font-size: 28px;
  }

}

@media screen and (max-width: 480px){

  #story-{{ section.id }}{
    padding: 90px 16px;
  }

  .story-letter{
    padding: 48px 24px;
  }

  .story-body p{
    font-size: 18px;
  }

}

</style>

{% schema %}
{
  "name": "Founder Letter",

  "settings": [

    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "06 / The Letter"
    },

    {
      "type": "text",
      "id": "title_line_1",
      "label": "Title Line 1",
      "default": "The secret behind"
    },

    {
      "type": "text",
      "id": "title_line_2",
      "label": "Title Line 2",
      "default": "the glow."
    },

    {
      "type": "text",
      "id": "dateline",
      "label": "Dateline",
      "default": "— Penned in the Atelier, Spring of 2026 —"
    },

    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Paragraph 1",
      "default": "Dearest reader, we built Dawn the way our grandmothers built rituals — slowly, on rosewood tables, with one hand on the kettle and the other on the cream. Skincare, we believed, should taste like the first hour of morning: warm, golden, certain."
    },

    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Paragraph 2",
      "default": "Each formula in the Glow Kit is whipped at low temperature, infused with botanicals from the gardens we trust, and pressed into glass we are not afraid to set on a marble dressing table. Nothing in this box is a stand-in for sleep, but every jar will love your skin like it has all the time in the world."
    },

    {
      "type": "textarea",
      "id": "paragraph_3",
      "label": "Paragraph 3",
      "default": "Half off, today only, because the first jar is always a leap of faith — and we would like the leap to be a small one."
    },

    {
      "type": "text",
      "id": "signature",
      "label": "Signature",
      "default": "— The Atelier at Dawn"
    }

  ],

  "presets": [
    {
      "name": "Founder Letter"
    }
  ]
}
{% endschema %}