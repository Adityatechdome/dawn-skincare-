<section class="luxury-story" style="--story-border-color: {{ section.settings.border_color }}; --story-accent-color: {{ section.settings.accent_color }}; --story-title-font: {{ section.settings.title_font_family }}; --story-title-size: {{ section.settings.title_font_size }}px; --story-title-color: {{ section.settings.title_color }}; --story-text-font: {{ section.settings.text_font_family }}; --story-text-size: {{ section.settings.text_font_size }}px; --story-text-color: {{ section.settings.text_color }}; --story-signature-font: {{ section.settings.signature_font_family }}; --story-signature-size: {{ section.settings.signature_font_size }}px; --story-signature-color: {{ section.settings.signature_color }};">
  <div class="story-container">
    <div class="story-content">
      <h2>{{ section.settings.story_title }}</h2>
      <p>{{ section.settings.story_text }}</p>
      <p class="story-signature">{{ section.settings.story_signature }}</p>
    </div>
  </div>
</section>

<style>
  .luxury-story {
    padding: 80px 56px;
    background: linear-gradient(135deg, #FBF6EE 0%, #F8F1E7 100%);
  }

  .story-container {
    max-width: 800px;
    margin: 0 auto;
    border: 2px solid var(--story-border-color, #B8945A);
    border-radius: 8px;
    padding: 60px 50px;
    background: rgba(255, 255, 255, 0.8);
    box-shadow: 0 10px 40px rgba(184, 148, 90, 0.1);
    position: relative;
  }

  .story-container::before {
    content: "";
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 1px solid var(--story-border-color, #B8945A);
    border-radius: 4px;
    opacity: 0.5;
    pointer-events: none;
  }

  .story-content {
    position: relative;
    z-index: 1;
    border-left: 3px solid var(--story-accent-color, #B8945A);
    padding-left: 30px;
  }

  .story-content h2 {
    font-family: var(--story-title-font, "Italiana"), serif;
    font-size: var(--story-title-size, 48px);
    color: var(--story-title-color, #2A2438);
    margin: 0 0 30px 0;
    letter-spacing: 0.08em;
  }

  .story-content p {
    font-family: var(--story-text-font, "Cormorant Garamond"), serif;
    font-size: var(--story-text-size, 20px);
    color: var(--story-text-color, #2A2438);
    line-height: 1.8;
    margin: 0 0 20px 0;
  }

  .story-signature {
    font-family: var(--story-signature-font, "Pinyon Script"), cursive;
    font-size: var(--story-signature-size, 32px);
    color: var(--story-signature-color, #B8945A);
    margin: 40px 0 0 0 !important;
  }

  @media (max-width: 768px) {
    .luxury-story {
      padding: 40px 20px;
    }

    .story-container {
      padding: 40px 30px;
      border-width: 1px;
    }

    .story-content {
      padding-left: 20px;
      border-left-width: 2px;
    }

    .story-content h2 {
      font-size: 32px;
    }

    .story-content p {
      font-size: 16px;
    }

    .story-signature {
      font-size: 24px;
    }
  }
</style>

{% schema %}
{
  "name": "Luxury Story",
  "settings": [
    {
      "type": "heading",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "story_title",
      "label": "Story Title",
      "default": "Our Journey"
    },
    {
      "type": "textarea",
      "id": "story_text",
      "label": "Story Text",
      "default": "Founded in the heart of luxury, our brand combines ancient botanical wisdom with modern skincare science. Every product is crafted with intention, infused with the finest ingredients from around the world. We believe that true beauty comes from within, and our mission is to help you achieve radiant, healthy skin that reflects your inner glow."
    },
    {
      "type": "text",
      "id": "story_signature",
      "label": "Founder Signature",
      "default": "With love, The Founder"
    },
    {
      "type": "heading",
      "content": "Border & Accent"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Frame Border Color",
      "default": "#B8945A"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Left Accent Line Color",
      "default": "#B8945A"
    },
    {
      "type": "heading",
      "content": "Title Settings"
    },
    {
      "type": "select",
      "id": "title_font_family",
      "label": "Title Font",
      "options": [
        { "value": "Italiana", "label": "Italiana" },
        { "value": "Cormorant Garamond", "label": "Cormorant Garamond" },
        { "value": "Inter", "label": "Inter" }
      ],
      "default": "Italiana"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 24,
      "max": 72,
      "step": 1,
      "unit": "px",
      "label": "Title Font Size",
      "default": 48
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#2A2438"
    },
    {
      "type": "heading",
      "content": "Body Text Settings"
    },
    {
      "type": "select",
      "id": "text_font_family",
      "label": "Body Font",
      "options": [
        { "value": "Cormorant Garamond", "label": "Cormorant Garamond" },
        { "value": "Inter", "label": "Inter" },
        { "value": "Italiana", "label": "Italiana" }
      ],
      "default": "Cormorant Garamond"
    },
    {
      "type": "range",
      "id": "text_font_size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Body Font Size",
      "default": 20
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#2A2438"
    },
    {
      "type": "heading",
      "content": "Signature Settings"
    },
    {
      "type": "select",
      "id": "signature_font_family",
      "label": "Signature Font",
      "options": [
        { "value": "Pinyon Script", "label": "Pinyon Script" },
        { "value": "Cormorant Garamond", "label": "Cormorant Garamond" },
        { "value": "Inter", "label": "Inter" }
      ],
      "default": "Pinyon Script"
    },
    {
      "type": "range",
      "id": "signature_font_size",
      "min": 16,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Signature Font Size",
      "default": 32
    },
    {
      "type": "color",
      "id": "signature_color",
      "label": "Signature Color",
      "default": "#B8945A"
    }
  ]
}
{% endschema %}
