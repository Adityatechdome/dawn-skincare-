<section id="testimonials-{{ section.id }}" class="royal-testimonials">

  <div class="testimonials-inner">

    <!-- HEADER -->

    <div class="testimonials-header">

      <div class="testimonials-eyebrow reveal">
        <span>{{ section.settings.eyebrow }}</span>
      </div>

      <h2 class="testimonials-title reveal">
        {{ section.settings.heading }}
      </h2>

      <p class="testimonials-subtitle reveal">
        {{ section.settings.subtitle }}
      </p>

    </div>

    <!-- GRID -->

    <div class="testimonials-grid">

      <!-- CARD 1 -->

      <div class="testimonial-card reveal card-1">

        <div class="wax-seal">
          <svg viewBox="0 0 56 56" width="56" height="56">
            <defs>
              <radialGradient id="ssg1" cx="35%" cy="30%">
                <stop offset="0%" stop-color="#D9BA82"/>
                <stop offset="100%" stop-color="#8C6F3F"/>
              </radialGradient>
            </defs>

            <circle cx="28" cy="28" r="24" fill="url(#ssg1)"/>
            <circle cx="28" cy="28" r="20" fill="none" stroke="rgba(0,0,0,0.2)"/>

            <text
              x="28"
              y="35"
              text-anchor="middle"
              font-family="Italiana, serif"
              font-size="22"
              fill="rgba(0,0,0,0.45)"
            >
              {{ section.settings.initial_1 }}
            </text>
          </svg>
        </div>

        <div class="testimonial-stars">
          ✦✦✦✦✦
        </div>

        <div class="testimonial-quote">
          “{{ section.settings.quote_1 }}”
        </div>

        <div class="testimonial-meta">

          <div class="testimonial-avatar">
            {{ section.settings.initial_1 }}
          </div>

          <div class="testimonial-user">
            <div class="testimonial-name">
              {{ section.settings.name_1 }}
            </div>

            <div class="testimonial-location">
              {{ section.settings.location_1 }} · VERIFIED
            </div>
          </div>

        </div>

      </div>

      <!-- CARD 2 -->

      <div class="testimonial-card reveal card-2">

        <div class="wax-seal">
          <svg viewBox="0 0 56 56" width="56" height="56">
            <defs>
              <radialGradient id="ssg2" cx="35%" cy="30%">
                <stop offset="0%" stop-color="#D9BA82"/>
                <stop offset="100%" stop-color="#8C6F3F"/>
              </radialGradient>
            </defs>

            <circle cx="28" cy="28" r="24" fill="url(#ssg2)"/>
            <circle cx="28" cy="28" r="20" fill="none" stroke="rgba(0,0,0,0.2)"/>

            <text
              x="28"
              y="35"
              text-anchor="middle"
              font-family="Italiana, serif"
              font-size="22"
              fill="rgba(0,0,0,0.45)"
            >
              {{ section.settings.initial_2 }}
            </text>
          </svg>
        </div>

        <div class="testimonial-stars">
          ✦✦✦✦✦
        </div>

        <div class="testimonial-quote">
          “{{ section.settings.quote_2 }}”
        </div>

        <div class="testimonial-meta">

          <div class="testimonial-avatar">
            {{ section.settings.initial_2 }}
          </div>

          <div class="testimonial-user">
            <div class="testimonial-name">
              {{ section.settings.name_2 }}
            </div>

            <div class="testimonial-location">
              {{ section.settings.location_2 }} · VERIFIED
            </div>
          </div>

        </div>

      </div>

      <!-- CARD 3 -->

      <div class="testimonial-card reveal card-3">

        <div class="wax-seal">
          <svg viewBox="0 0 56 56" width="56" height="56">
            <defs>
              <radialGradient id="ssg3" cx="35%" cy="30%">
                <stop offset="0%" stop-color="#D9BA82"/>
                <stop offset="100%" stop-color="#8C6F3F"/>
              </radialGradient>
            </defs>

            <circle cx="28" cy="28" r="24" fill="url(#ssg3)"/>
            <circle cx="28" cy="28" r="20" fill="none" stroke="rgba(0,0,0,0.2)"/>

            <text
              x="28"
              y="35"
              text-anchor="middle"
              font-family="Italiana, serif"
              font-size="22"
              fill="rgba(0,0,0,0.45)"
            >
              {{ section.settings.initial_3 }}
            </text>
          </svg>
        </div>

        <div class="testimonial-stars">
          ✦✦✦✦✦
        </div>

        <div class="testimonial-quote">
          “{{ section.settings.quote_3 }}”
        </div>

        <div class="testimonial-meta">

          <div class="testimonial-avatar">
            {{ section.settings.initial_3 }}
          </div>

          <div class="testimonial-user">
            <div class="testimonial-name">
              {{ section.settings.name_3 }}
            </div>

            <div class="testimonial-location">
              {{ section.settings.location_3 }} · VERIFIED
            </div>
          </div>

        </div>

      </div>

    </div>

  </div>

</section>

<style>

#testimonials-{{ section.id }}{
  position: relative;

  width: 100vw;
  max-width: 100vw;

  left: 50%;
  right: 50%;

  margin-left: -50vw;
  margin-right: -50vw;

  overflow: hidden;

  background: #F8F1E7;

  padding: 140px 56px;
}

#testimonials-{{ section.id }} *{
  box-sizing: border-box;
}

.testimonials-inner{
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
}

/* HEADER */

.testimonials-header{
  text-align: center;
  margin-bottom: 80px;
}

.testimonials-eyebrow{
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;

  margin-bottom: 32px;
}

.testimonials-eyebrow::before,
.testimonials-eyebrow::after{
  content: "";
  width: 36px;
  height: 1px;
  background: #B8945A;
  opacity: 0.6;
}

.testimonials-eyebrow span{
  font-family: "Inter", sans-serif;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: #8C6F3F;
}

.testimonials-title{
  max-width: 14ch;
  margin: 0 auto 24px;

  font-family: "Italiana", serif;
  font-size: clamp(40px, 5.5vw, 84px);
  line-height: 1;
  font-weight: 400;

  color: #2A2438;
}

.testimonials-subtitle{
  max-width: 56ch;
  margin: 0 auto;

  font-family: "Cormorant Garamond", serif;
  font-style: italic;
  font-size: 20px;
  line-height: 1.5;

  color: rgba(42,36,56,0.72);
}

/* GRID */

.testimonials-grid{
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 28px;

  max-width: 1320px;
  margin: 0 auto;
}

/* CARD */

.testimonial-card{
  position: relative;

  padding: 48px 36px 40px;

  border: 1px solid rgba(184,148,90,0.20);

  background:
    repeating-linear-gradient(
      180deg,
      transparent 0 30px,
      rgba(184,148,90,0.08) 30px 31px
    ),
    #FBF6EE;

  box-shadow:
    0 30px 60px -40px rgba(91,74,122,0.30);

  transition:
    transform 0.4s ease,
    box-shadow 0.4s ease;
}

.card-1{
  transform: rotate(-1.2deg);
}

.card-2{
  transform: rotate(0.6deg);
}

.card-3{
  transform: rotate(-0.4deg);
}

.testimonial-card:hover,
.testimonial-card.is-active{
  transform: rotate(0deg) translateY(-4px);
}

/* WAX SEAL */

.wax-seal{
  position: absolute;
  top: -16px;
  right: 24px;
}

/* STARS */

.testimonial-stars{
  margin-bottom: 16px;

  font-family: "Italiana", serif;
  font-size: 18px;
  letter-spacing: 0.3em;

  color: #8C6F3F;
}

/* QUOTE */

.testimonial-quote{
  margin-bottom: 28px;

  font-family: "Pinyon Script", cursive;
  font-size: 28px;
  line-height: 1.35;

  color: #3D3158;

  text-wrap: pretty;
}

/* META */

.testimonial-meta{
  display: flex;
  align-items: center;
  gap: 14px;
}

.testimonial-avatar{
  width: 44px;
  height: 44px;

  border-radius: 50%;

  background:
    linear-gradient(
      135deg,
      #C9B8DC,
      #E8C9CC
    );

  display: flex;
  align-items: center;
  justify-content: center;

  font-family: "Italiana", serif;
  font-size: 18px;

  color: #F8F1E7;
}

.testimonial-name{
  font-family: "Cormorant Garamond", serif;
  font-size: 16px;
  font-weight: 600;

  color: #2A2438;
}

.testimonial-location{
  margin-top: 4px;

  font-family: "JetBrains Mono", monospace;
  font-size: 10px;
  letter-spacing: 0.20em;
  text-transform: uppercase;

  opacity: 0.55;
}

/* REVEAL */

.reveal{
  opacity: 0;
  transform: translateY(40px);

  animation: revealUp 0.9s cubic-bezier(0.2,0.8,0.2,1) forwards;
}

.card-1.reveal{
  animation-delay: 0.1s;
}

.card-2.reveal{
  animation-delay: 0.24s;
}

.card-3.reveal{
  animation-delay: 0.38s;
}

@keyframes revealUp{
  to{
    opacity: 1;
    transform: translateY(0);
  }
}

/* RESPONSIVE */

@media screen and (max-width: 999px){

  .testimonials-grid{
    grid-template-columns: repeat(2,1fr);
  }

}

@media screen and (max-width: 700px){

  #testimonials-{{ section.id }}{
    padding: 90px 24px;
  }

}

@media screen and (max-width: 600px){

  #testimonials-{{ section.id }}{
    padding: 90px 16px;
  }

  .testimonials-grid{
    grid-template-columns: 1fr;

    max-width: 480px;
  }

  .card-1{
    transform: rotate(-0.6deg);
  }

  .card-2{
    transform: rotate(0.4deg);
  }

  .card-3{
    transform: rotate(-0.5deg);
  }

  .testimonial-card{
    padding: 42px 24px 32px;
  }

  .testimonial-quote{
    font-size: 24px;
  }

}

/* TOUCH */

@media (hover:none){

  .testimonial-card{
    cursor: pointer;
  }

}

</style>

<script>

document.querySelectorAll('#testimonials-{{ section.id }} .testimonial-card')
.forEach(card => {

  card.addEventListener('click', () => {
    card.classList.toggle('is-active');
  });

});

</script>

