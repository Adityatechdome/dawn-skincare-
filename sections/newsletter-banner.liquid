<div
  id="bridgerton-popup-{{ section.id }}"
  class="bridgerton-popup-wrapper"
  aria-hidden="true"
>

  <div class="bridgerton-popup-backdrop"></div>

  <div
    class="bridgerton-popup"
    role="dialog"
    aria-modal="true"
    aria-labelledby="bridgerton-popup-title"
  >

    <!-- CLOSE -->

    <button
      type="button"
      class="bridgerton-popup-close"
      aria-label="Close popup"
    >
      ×
    </button>

    <div class="bridgerton-popup-content">

      <!-- EYEBROW -->

      <div class="bridgerton-popup-eyebrow reveal">
        <span>
          {{ section.settings.eyebrow }}
        </span>
      </div>

      <!-- TITLE -->

      <h2
        id="bridgerton-popup-title"
        class="bridgerton-popup-title reveal"
      >

        {{ section.settings.heading_line_1 }}

        <em>
          {{ section.settings.heading_line_2 }}
        </em>

      </h2>

      <!-- SUBTITLE -->

      <p class="bridgerton-popup-subtitle reveal">
        {{ section.settings.subheading }}
      </p>

      <!-- FORM -->

      {% form 'customer', class: 'bridgerton-popup-form reveal' %}

        {% if form.posted_successfully? %}
          <div class="bridgerton-popup-success">
            {{ section.settings.success_message }}
          </div>
        {% endif %}

        {% if form.errors %}
          <div class="bridgerton-popup-error">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <input
          type="hidden"
          name="contact[tags]"
          value="Bridgerton Newsletter"
        >

        <input
          type="hidden"
          name="customer[tags]"
          value="Bridgerton Newsletter"
        >

        <input
          type="email"
          name="contact[email]"
          class="bridgerton-popup-input"
          placeholder="{{ section.settings.placeholder }}"
          required
          autocorrect="off"
          autocapitalize="off"
        >

        <button
          type="submit"
          class="bridgerton-popup-button"
        >
          {{ section.settings.button_text }}
        </button>

      {% endform %}

      <!-- NOTE -->

      <div class="bridgerton-popup-note reveal">
        {{ section.settings.note }}
      </div>

    </div>

  </div>

</div>

<style>

/* =========================================
   REMOVE HOMEPAGE BLANK SPACE
========================================= */

#shopify-section-{{ section.id }}{
  position: absolute !important;

  width: 0 !important;
  height: 0 !important;

  margin: 0 !important;
  padding: 0 !important;

  overflow: hidden !important;
}

/* =========================================
   POPUP WRAPPER
========================================= */

#bridgerton-popup-{{ section.id }}{
  position: fixed;
  inset: 0;

  z-index: 9999;

  display: flex;
  align-items: center;
  justify-content: center;

  padding: 24px;

  opacity: 0;
  visibility: hidden;

  transition:
    opacity 0.45s ease,
    visibility 0.45s ease;
}

#bridgerton-popup-{{ section.id }}.show{
  opacity: 1;
  visibility: visible;
}

#bridgerton-popup-{{ section.id }} *{
  box-sizing: border-box;
}

/* =========================================
   BACKDROP
========================================= */

.bridgerton-popup-backdrop{
  position: absolute;
  inset: 0;

  background:
    rgba(42,36,56,0.45);

  backdrop-filter: blur(10px);
}

/* =========================================
   POPUP
========================================= */

.bridgerton-popup{
  position: relative;
  z-index: 2;

  width: 100%;
  max-width: 620px;

  overflow: hidden;

  border-radius: 32px;

  border:
    1px solid rgba(217,186,130,0.35);

  background:
    linear-gradient(
      180deg,
      rgba(248,241,231,0.92),
      rgba(239,228,210,0.88)
    );

  backdrop-filter: blur(24px);

  box-shadow:
    0 40px 120px -30px rgba(42,36,56,0.45);

  padding:
    72px 56px 56px;
}

/* GOLD GLOW */

.bridgerton-popup::before{
  content: "";

  position: absolute;
  top: -20%;
  left: 50%;

  transform: translateX(-50%);

  width: 140%;
  height: 240px;

  background:
    radial-gradient(
      ellipse at center,
      rgba(217,186,130,0.20) 0%,
      transparent 70%
    );

  pointer-events: none;
}

/* =========================================
   CLOSE BUTTON
========================================= */

.bridgerton-popup-close{
  position: absolute;

  top: 18px;
  right: 18px;

  width: 42px;
  height: 42px;

  border: none;
  outline: none;

  cursor: pointer;

  border-radius: 50%;

  background:
    rgba(255,255,255,0.45);

  backdrop-filter: blur(10px);

  color: #5B4A7A;

  font-size: 26px;
  line-height: 1;

  transition:
    background 0.2s ease,
    transform 0.2s ease;
}

.bridgerton-popup-close:hover{
  background:
    rgba(255,255,255,0.82);

  transform: rotate(90deg);
}

/* =========================================
   CONTENT
========================================= */

.bridgerton-popup-content{
  position: relative;
  z-index: 2;

  text-align: center;
}

/* =========================================
   EYEBROW
========================================= */

.bridgerton-popup-eyebrow{
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;

  margin-bottom: 28px;
}

.bridgerton-popup-eyebrow::before,
.bridgerton-popup-eyebrow::after{
  content: "";

  width: 36px;
  height: 1px;

  background: #B8945A;

  opacity: 0.6;
}

.bridgerton-popup-eyebrow span{
  font-family: "JetBrains Mono", monospace;
  font-size: 10px;

  letter-spacing: 0.32em;
  text-transform: uppercase;

  color: #8C6F3F;
}

/* =========================================
   TITLE
========================================= */

.bridgerton-popup-title{
  margin: 0 0 18px;

  font-family: "Italiana", serif;
  font-size: clamp(44px,6vw,74px);
  line-height: 0.95;
  font-weight: 400;

  color: #2A2438;
}

.bridgerton-popup-title em{
  display: block;

  margin-top: 6px;

  font-family: "Pinyon Script", cursive;
  font-style: normal;
  font-size: 1.08em;

  color: #8C6F3F;

  text-transform: none;
}

/* =========================================
   SUBTITLE
========================================= */

.bridgerton-popup-subtitle{
  max-width: 32ch;

  margin:
    0 auto 36px;

  font-family: "Cormorant Garamond", serif;
  font-style: italic;
  font-size: 22px;
  line-height: 1.5;

  color:
    rgba(42,36,56,0.78);
}

/* =========================================
   FORM
========================================= */

.bridgerton-popup-form{
  display: flex;
  flex-direction: column;
  gap: 16px;

  width: 100%;
  max-width: 420px;

  margin: 0 auto;
}

/* SUCCESS */

.bridgerton-popup-success{
  margin-bottom: 18px;

  padding: 14px 18px;

  border-radius: 18px;

  background:
    rgba(217,186,130,0.12);

  border:
    1px solid rgba(217,186,130,0.22);

  font-family: "Cormorant Garamond", serif;
  font-style: italic;
  font-size: 18px;
  line-height: 1.5;

  color: #5B4A7A;
}

/* ERROR */

.bridgerton-popup-error{
  margin-bottom: 18px;

  padding: 14px 18px;

  border-radius: 18px;

  background:
    rgba(176,122,130,0.10);

  border:
    1px solid rgba(176,122,130,0.20);

  font-family: "Inter", sans-serif;
  font-size: 13px;
  line-height: 1.6;

  color: #7A4450;
}

/* INPUT */

.bridgerton-popup-input{
  width: 100%;

  border:
    1px solid rgba(184,148,90,0.25);

  border-radius: 999px;

  background:
    rgba(255,255,255,0.35);

  backdrop-filter: blur(10px);

  padding:
    18px 24px;

  outline: none;

  font-family: "Inter", sans-serif;
  font-size: 14px;

  color: #2A2438;
}

.bridgerton-popup-input::placeholder{
  color:
    rgba(42,36,56,0.5);
}

/* BUTTON */

.bridgerton-popup-button{
  border: none;
  outline: none;

  cursor: pointer;

  border-radius: 999px;

  padding:
    20px 32px;

  background:
    #2A2438;

  color:
    #F8F1E7;

  font-family: "Inter", sans-serif;
  font-size: 12px;
  font-weight: 500;

  letter-spacing: 0.24em;
  text-transform: uppercase;

  transition:
    transform 0.3s ease,
    background 0.3s ease;
}

.bridgerton-popup-button:hover{
  transform: translateY(-2px);

  background:
    #5B4A7A;
}

/* NOTE */

.bridgerton-popup-note{
  margin-top: 24px;

  font-family: "JetBrains Mono", monospace;
  font-size: 10px;

  letter-spacing: 0.22em;
  text-transform: uppercase;

  color:
    rgba(42,36,56,0.55);
}

/* =========================================
   MOBILE
========================================= */

@media screen and (max-width: 700px){

  .bridgerton-popup{
    padding:
      64px 28px 36px;

    border-radius: 28px;
  }

  .bridgerton-popup-title{
    font-size:
      clamp(38px,10vw,58px);
  }

  .bridgerton-popup-subtitle{
    font-size: 20px;
  }

}

@media screen and (max-width: 480px){

  #bridgerton-popup-{{ section.id }}{
    padding: 16px;
  }

  .bridgerton-popup{
    padding:
      56px 22px 30px;
  }

  .bridgerton-popup-input{
    padding:
      16px 20px;
  }

  .bridgerton-popup-button{
    padding:
      18px 24px;

    font-size: 11px;
  }

}

</style>

<script>

(function(){

  const popup =
    document.getElementById(
      'bridgerton-popup-{{ section.id }}'
    );

  const closeBtn =
    popup.querySelector(
      '.bridgerton-popup-close'
    );

  /* CHANGE THIS VERSION TO RETEST POPUP */

  const STORAGE_KEY =
    'dawn-bridgerton-popup-v2';

  const SEVEN_DAYS =
    7 * 24 * 60 * 60 * 1000;

  function shouldShowPopup(){

    const stored =
      localStorage.getItem(STORAGE_KEY);

    if(!stored) return true;

    const lastSeen =
      parseInt(stored, 10);

    return (
      Date.now() - lastSeen
    ) > SEVEN_DAYS;

  }

  function showPopup(){

    if(!shouldShowPopup()) return;

    popup.classList.add('show');

    popup.setAttribute(
      'aria-hidden',
      'false'
    );

    document.body.style.overflow = 'hidden';

  }

  function closePopup(){

    popup.classList.remove('show');

    popup.setAttribute(
      'aria-hidden',
      'true'
    );

    document.body.style.overflow = '';

    localStorage.setItem(
      STORAGE_KEY,
      Date.now().toString()
    );

  }

  let popupTriggered = false;

  function handleScroll(){

    if(popupTriggered) return;

    if(
      window.scrollY >
      window.innerHeight * 0.45
    ){

      popupTriggered = true;

      setTimeout(showPopup, 800);

    }

  }

  window.addEventListener(
    'scroll',
    handleScroll,
    { passive: true }
  );

  closeBtn.addEventListener(
    'click',
    closePopup
  );

  popup
    .querySelector('.bridgerton-popup-backdrop')
    .addEventListener(
      'click',
      closePopup
    );

  document.addEventListener(
    'keydown',
    function(event){

      if(
        event.key === 'Escape'
      ){
        closePopup();
      }

    }
  );

  {% if form.posted_successfully? %}

    popup.classList.add('show');

    popup.setAttribute(
      'aria-hidden',
      'false'
    );

  {% endif %}

})();

</script>

{% schema %}
{
  "name": "Bridgerton Popup",

  "settings": [

    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "THE SOCIETY PAPERS"
    },

    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading Line 1",
      "default": "A letter awaits"
    },

    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading Line 2",
      "default": "your arrival."
    },

    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtitle",
      "default": "Join Lady Bridgerton’s private correspondence for rituals, gifts, and whispers from the atelier."
    },

    {
      "type": "text",
      "id": "placeholder",
      "label": "Input Placeholder",
      "default": "Enter your correspondence address"
    },

    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Receive the Letter"
    },

    {
      "type": "text",
      "id": "success_message",
      "label": "Success Message",
      "default": "Your invitation has been accepted. Watch for correspondence from the atelier."
    },

    {
      "type": "text",
      "id": "note",
      "label": "Micro Note",
      "default": "Private Atelier Notes · Seasonal Rituals · Early Access"
    }

  ],

  "presets": [
    {
      "name": "Bridgerton Popup"
    }
  ]
}
{% endschema %}