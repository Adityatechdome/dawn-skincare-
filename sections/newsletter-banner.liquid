<section class="newsletter">
  <div class="newsletter-banner">
    {% if section.settings.background_image != blank %}
      <img
        src="{{ section.settings.background_image | image_url: width: 1800 }}"
        alt="Newsletter background"
        class="newsletter-banner__bg banner_desktop"
        loading="lazy"
      >
    {% endif %}

    {% if section.settings.background_image_mobile != blank %}
      <img
        src="{{ section.settings.background_image_mobile | image_url: width: 1200 }}"
        alt="Newsletter background"
        class="newsletter-banner__bg banner_mobile"
        loading="lazy"
      >
    {% endif %}

    <div class="newsletter-banner__overlay">
      <div class="newsletter-banner__content">
        <h2 class="newsletter-banner__title">{{ section.settings.heading }}</h2>
        <p class="newsletter-banner__subtitle">{{ section.settings.subheading }}</p>

        <form
          method="post"
          action="{{ routes.newsletter_subscribe_url }}"
          accept-charset="UTF-8"
          class="newsletter-banner__form"
        >
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="✓">

          <input
            type="email"
            name="contact[email]"
            class="newsletter-banner__input"
            placeholder="{{ section.settings.placeholder }}"
            required
          >
          <button type="submit" class="newsletter-banner__button">
            <svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M14.3965 10.9609L22.9808 10.9609L22.9808 19.5452" stroke="white" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M10.96 22.9805L22.8606 11.0799" stroke="white" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .newsletter {
    background: #eeeae1;
    text-align: center;
    padding: 90px 135px;
  }
  .newsletter-banner {
    position: relative;
    overflow: hidden;
  }

  /* Background image */
  .newsletter-banner__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .banner_mobile {
    display: none;
  }

  /* Dark overlay on top of image */
  .newsletter-banner__overlay {
    position: relative;
    z-index: 1;
    padding: 80px 40px;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
  }

  .newsletter-banner__content {
    max-width: 700px;
    margin: 0 auto;
  }

  .newsletter-banner__title {
    font-family: Recoleta;
    font-weight: 600;
    font-size: 48px;
    line-height: 58px;
    letter-spacing: 0%;
    margin: 0 0 16px;
    color: #fff;
    text-transform: capitalize;
  }

  .newsletter-banner__subtitle {
    font-family: Roboto;
    font-weight: 400;
    font-size: 18px;
    line-height: 28px;
    letter-spacing: 0px;
    text-align: center;
    color: #fff;
    margin: 0 0 48px;
  }

  .newsletter-banner__form {
    display: flex;
    justify-content: center;
    align-items: center;
    background: #fff;
    border-radius: 50px;
    overflow: hidden;
    max-width: 400px;
    margin: 0 auto;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .newsletter-banner__input {
    flex: 1;
    border: none;
    outline: none;
    padding: 16px 20px;
    font-family: Roboto;
    font-weight: 400;
    font-size: 16px;
    line-height: 24px;
    letter-spacing: 0%;
    border-radius: 50px 0 0 50px;
  }

  .newsletter-banner__input::placeholder {
    color: #98a2b3;
  }

  .newsletter-banner__button {
    background: #1a432e;
    color: #fff;
    border: none;
    padding: 10px;
    margin-right: 5px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    transition: background 0.3s ease;
  }

  .newsletter-banner__button svg {
    width: 24px;
    height: 24px;
  }

  .newsletter-banner__button:hover {
    background: #0d2f26;
  }

  @media (max-width: 1000px) {
    .newsletter {
      padding: 50px 0;
    }

    .banner_desktop {
      display: none;
    }

    .banner_mobile {
      display: block;
    }

    .newsletter-banner__overlay {
      padding: 40px;
    }

    .newsletter-banner__title {
      font-family: Valky;
      font-weight: 400;
      font-size: 36px;
      line-height: 58px;
      letter-spacing: 0%;
      text-align: center;
      margin: 0 0 16px;
    }

    .newsletter-banner__subtitle {
      font-family: Roboto;
      font-weight: 400;
      font-size: 18px;
      line-height: 28px;
      letter-spacing: 0px;
      text-align: center;
      margin:0 0 48px;
    }

    .newsletter-banner__form {
      max-width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Newsletter Banner (Image)",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background Image Mobile"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stay Connected, Stay Informed"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Subscribe to receive exclusive updates, tips, and promotions straight to your inbox. Join our community for expert advice and resources to support your care journey."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input Placeholder",
      "default": "Enter your email address here"
    }
  ],
  "presets": [
    {
      "name": "Newsletter Banner"
    }
  ]
}
{% endschema %}
