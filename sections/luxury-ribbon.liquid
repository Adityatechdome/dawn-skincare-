<section class="ribbon" id="ribbon">
  <div class="ribbon-track">
    {% for i in (1..3) %}
      <span>{{ section.settings.item_1_text }}</span>
      <span>{{ section.settings.item_2_text }}</span>
      <span>{{ section.settings.item_3_text }}</span>
      <span>{{ section.settings.item_4_text }}</span>
    {% endfor %}
  </div>
</section>

<style>
  .ribbon {
    background: #3D3158;
    color: #D9BA82;
    padding: 14px 0;
    overflow: hidden;
    position: relative;
  }

  .ribbon-track {
    display: flex;
    gap: 56px;
    white-space: nowrap;
    animation: ribbon 40s linear infinite;
    font-family: "Italiana", serif;
    font-size: 18px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .ribbon-track span {
    display: inline-flex;
    align-items: center;
    gap: 56px;
  }

  .ribbon-track span::after {
    content: "❦";
    color: #B8945A;
    font-size: 22px;
  }

  @keyframes ribbon {
    to {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    .ribbon-track {
      font-size: 14px;
      gap: 40px;
    }

    .ribbon-track span {
      gap: 40px;
    }
  }
</style>

{% schema %}
{
  "name": "Luxury Ribbon",
  "settings": [
    {
      "type": "text",
      "id": "item_1_text",
      "label": "Marquee Item 1",
      "default": "Free BB Cream — Today Only"
    },
    {
      "type": "text",
      "id": "item_2_text",
      "label": "Marquee Item 2",
      "default": "Glow Like Royalty"
    },
    {
      "type": "text",
      "id": "item_3_text",
      "label": "Marquee Item 3",
      "default": "50% Off The Full Ritual"
    },
    {
      "type": "text",
      "id": "item_4_text",
      "label": "Marquee Item 4",
      "default": "Ships in Velvet, Always"
    }
  ]
}
{% endschema %}
