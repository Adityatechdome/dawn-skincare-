        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image",
          "info": "Leave empty to use collection image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Category",
      "category": "Collections",
      "blocks": [
        {
          "type": "category"
        },
        {
          "type": "category"
        },
        {
          "type": "category"
        }
      ]
    }
  ]
}
{% endschema %}
