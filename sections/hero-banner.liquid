{% schema %}
  {
    "name": "Hero Banner",
    "tag": "section",
    "class": "section-hero-banner",
    "settings": [
      {
        "type": "image_picker",
        "id": "image",
        "label": "Banner Image"
      },
      {
        "type": "image_picker",
        "id": "image_mobile",
        "label": "Mobile Banner Image (Optional)"
      },
      {
        "type": "url",
        "id": "link",
        "label": "Banner Link"
      },
      {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Padding Top",
        "default": 0
      }, {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Padding Bottom",
        "default": 0
      }
    ],
    "presets": [
      {
        "name": "Hero Banner"
      }
    ]
  }
{% endschema %}

{% liquid
  assign banner_image = section.settings.image
  assign banner_image_mobile = section.settings.image_mobile
  assign banner_loading = 'lazy'
  assign banner_fetch_priority = 'auto'
  assign banner_preload = false
  assign banner_decoding = 'async'
  assign is_collection_lcp_banner = false
  assign banner_base_width = 3840
  assign desktop_sizes = '100vw'
  assign mobile_sizes = '100vw'

  if section.index == 1
    assign banner_loading = 'eager'
    assign banner_fetch_priority = 'high'
    assign banner_preload = true
    assign banner_decoding = 'async'
  endif

  if banner_image_mobile != blank
    # Prevent unnecessary bandwidth for the hidden image variant.
    assign desktop_sizes = '(min-width: 750px) 100vw, 0px'
    assign mobile_sizes = '(min-width: 750px) 0px, 100vw'
  endif

  if request.page_type == 'collection' and collection.image != blank
    assign banner_image = collection.image
    assign banner_image_mobile = blank
    assign is_collection_lcp_banner = true
    assign banner_loading = 'eager'
    assign banner_fetch_priority = 'high'
    assign banner_preload = true
    assign banner_decoding = 'async'
    assign banner_base_width = 1780
  endif

  if banner_image_mobile == blank
    assign desktop_sizes = '100vw'
    assign mobile_sizes = '100vw'
  endif
%}

{% style %}
  .section-hero-banner {
    width: 100%;
    margin: 0;
    padding: 0;
    display: block;
  }

  .hero-banner-section {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .hero-banner-section {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .hero-banner-container {
    width: 100%;
    display: block;
    line-height: 0;
  }

  .hero-banner-link {
    display: block;
    width: 100%;
  }

  .hero-banner-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  {% if banner_image_mobile != blank %}
    .hero-banner-image.desktop {
      display: none;
    }
    .hero-banner-image.mobile {
      display: block;
    }

    @media screen and (min-width: 750px) {
      .hero-banner-image.desktop {
        display: block;
      }
      .hero-banner-image.mobile {
        display: none;
      }
    }
  {% endif %}
{% endstyle %}

<div class="hero-banner-section">
  <div class="hero-banner-container">
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}" class="hero-banner-link">
    {%- endif -%}
    {% if banner_image != blank %}
      {% if is_collection_lcp_banner %}
        <img
          src="{{ banner_image | image_url: width: 1780 }}"
          srcset="
            {{ banner_image | image_url: width: 375 }} 375w,
            {{ banner_image | image_url: width: 550 }} 550w,
            {{ banner_image | image_url: width: 750 }} 750w,
            {{ banner_image | image_url: width: 1100 }} 1100w,
            {{ banner_image | image_url: width: 1500 }} 1500w,
            {{ banner_image | image_url: width: 1780 }} 1780w,
            {{ banner_image | image_url: width: 2000 }} 2000w,
            {{ banner_image | image_url: width: 3000 }} 3000w,
            {{ banner_image | image_url: width: 3840 }} 3840w
          "
          sizes="100vw"
          width="{{ banner_image.width }}"
          height="{{ banner_image.height }}"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          class="hero-banner-image desktop"
          alt="{{ banner_image.alt | escape }}"
        >
      {% else %}
        {{ banner_image | image_url: width: banner_base_width | image_tag:
 loading: banner_loading,
 decoding: banner_decoding,
 fetchpriority: banner_fetch_priority,
 preload: banner_preload,
 width: banner_image.width,
 height: banner_image.height,
 class: 'hero-banner-image desktop',
 sizes: desktop_sizes,
 widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
        }}
      {% endif %}

      {% if banner_image_mobile != blank %}
        {{ banner_image_mobile | image_url: width: 750 | image_tag:
 loading: banner_loading,
 decoding: banner_decoding,
 fetchpriority: banner_fetch_priority,
 preload: banner_preload,
 width: banner_image_mobile.width,
 height: banner_image_mobile.height,
 class: 'hero-banner-image mobile',
 sizes: mobile_sizes,
 widths: '375, 550, 750'
        }}
      {% endif %}
    {% else %}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}
    {%- if section.settings.link != blank -%}
      </a>
    {%- endif -%}
  </div>
</div>
