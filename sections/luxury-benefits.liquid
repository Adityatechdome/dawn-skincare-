<style>
html,
body {
  overflow-x: hidden;
}

/* SECTION */

.section.benefits {
  position: relative;
  overflow: hidden;

  width: 100vw;
  max-width: 100vw;

  margin: 0;
  left: 0;

  padding: 140px 56px;

  background:
    radial-gradient(circle at top left,
    rgba(91,74,122,0.95) 0%,
    rgba(61,49,88,0.92) 32%,
    #2A2438 70%),

    linear-gradient(
      180deg,
      #3D3158 0%,
      #2A2438 100%
    );

  color: #F8F1E7;

  box-sizing: border-box;
}

/* GLOW */

.benefits-glow {
  position: absolute;
  inset: 0;

  pointer-events: none;

  background:
    radial-gradient(
      ellipse at 20% 0%,
      rgba(91,74,122,0.85) 0%,
      transparent 60%
    ),

    radial-gradient(
      ellipse at 85% 100%,
      rgba(184,148,90,0.24) 0%,
      transparent 60%
    ),

    radial-gradient(
      ellipse at center,
      rgba(91,74,122,0.22) 0%,
      transparent 70%
    );
}

/* HEADER */

.benefits-header {
  position: relative;
  z-index: 2;

  text-align: center;

  margin-bottom: 80px;
}

.benefits-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 12px;

  color: #D9BA82;

  font-family: "Inter", sans-serif;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.32em;
  text-transform: uppercase;
}

.benefits-eyebrow::before,
.benefits-eyebrow::after {
  content: "";

  width: 36px;
  height: 1px;

  background: #D9BA82;
}

.benefits-title {
  max-width: 14ch;

  margin: 24px auto 16px;

  text-wrap: pretty;

  font-family: "Italiana", serif;
  font-size: clamp(40px, 5.5vw, 84px);
  font-weight: 400;
  line-height: 1;
  letter-spacing: -0.005em;

  color: #F8F1E7;
}

.benefits-subtitle {
  max-width: 56ch;

  margin: 0 auto;

  font-family: "Cormorant Garamond", serif;
  font-style: italic;
  font-size: 20px;
  line-height: 1.5;

  color: rgba(248,241,231,0.72);
}

/* GRID */

.benefits-grid {
  position: relative;
  z-index: 2;

  display: grid;
  grid-template-columns: repeat(4,minmax(0,1fr));

  align-items: start;

  gap: 24px;

  width: 100%;
  max-width: 1280px;

  margin: 0 auto;
}

/* BENEFIT */

.benefit {
  position: relative;

  display: flex;
  flex-direction: column;
  align-items: center;

  text-align: center;

  padding: 32px 24px 40px;

  min-height: 100%;
}

/* SEAL */

.seal {
  margin: 0 auto 28px;

  width: 140px;
  height: 140px;

  filter:
    drop-shadow(0 12px 24px rgba(0,0,0,0.35));

  transition:
    transform 0.5s cubic-bezier(0.2,0.8,0.2,1);
}

.benefit:hover .seal {
  transform:
    rotate(-8deg)
    scale(1.05);
}

/* TEXT */

.benefit-name {
  margin-bottom: 12px;

  font-family: "Italiana", serif;
  font-size: 28px;
  line-height: 1.1;

  color: #F8F1E7;
}

.benefit-desc {
  max-width: 24ch;

  margin: 0 auto;

  text-wrap: pretty;

  font-family: "Cormorant Garamond", serif;
  font-style: italic;
  font-size: 16px;
  line-height: 1.5;

  color: rgba(248,241,231,0.78);
}

/* REVEAL */

.reveal {
  opacity: 0;
  transform: translateY(28px);

  transition:
    opacity 0.9s cubic-bezier(0.2,0.8,0.2,1),
    transform 0.9s cubic-bezier(0.2,0.8,0.2,1);
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* TABLET */

@media (max-width: 999px) {

  .section.benefits {
    padding: 120px 32px;
  }

  .benefits-grid {
    grid-template-columns: repeat(2,1fr);

    max-width: 720px;
  }

}

/* MOBILE */

@media (max-width: 600px) {

  .section.benefits {
    padding: 90px 24px;
  }

  .benefits-grid {
    grid-template-columns: repeat(2,1fr);

    gap: 18px;

    max-width: 100%;
  }

  .seal {
    width: 110px;
    height: 110px;
  }

  .seal svg {
    width: 110px;
    height: 110px;
  }

  .benefit-name {
    font-size: 22px;
  }

}
</style>

<script>
document.addEventListener("DOMContentLoaded", () => {

  const reveals = document.querySelectorAll(".reveal");

  const observer = new IntersectionObserver((entries) => {

    entries.forEach((entry, index) => {

      if (entry.isIntersecting) {

        setTimeout(() => {
          entry.target.classList.add("visible");
        }, index * 120);

      }

    });

  }, {
    threshold: 0.12
  });

  reveals.forEach(el => observer.observe(el));

});
</script>

