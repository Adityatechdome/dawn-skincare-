<style>

/* FORCE TRUE FULL WIDTH */

#shopify-section-{{ section.id }}{
  width: 100% !important;
  max-width: 100% !important;

  margin: 0 !important;
  padding: 0 !important;

  overflow: hidden !important;

  background: #3D3158 !important;
}

#shopify-section-{{ section.id }} > div{
  margin: 0 !important;
  max-width: 100% !important;
}

html,
body{
  overflow-x: hidden;
}

/* SECTION */

.section.benefits{
  position: relative;

  overflow: hidden;

  width: 100%;

  margin: 0;

  padding: 110px 32px;

  background: #3D3158;

  box-sizing: border-box;
}

/* BACKGROUND */

.benefits-glow{
  position: absolute;
  inset: 0;

  background: #3D3158;

  pointer-events: none;
}

/* HEADER */

.benefits-header{
  position: relative;
  z-index: 2;

  text-align: center;

  margin-bottom: 90px;
}

.benefits-eyebrow{
  display: inline-flex;
  align-items: center;
  gap: 12px;

  color: #D9BA82;

  font-family: "Inter", sans-serif;
  font-size: 11px;
  font-weight: 500;

  letter-spacing: 0.32em;
  text-transform: uppercase;
}

.benefits-eyebrow::before,
.benefits-eyebrow::after{
  content: "";

  width: 36px;
  height: 1px;

  background: #D9BA82;
}

.benefits-title{
  max-width: 14ch;

  margin: 24px auto 18px;

  font-family: "Italiana", serif;
  font-size: clamp(48px, 6vw, 92px);
  font-weight: 400;
  line-height: 1;
  letter-spacing: -0.02em;

  color: #F8F1E7;
}

.benefits-subtitle{
  max-width: 56ch;

  margin: 0 auto;

  font-family: "Cormorant Garamond", serif;
  font-style: italic;
  font-size: 22px;
  line-height: 1.6;

  color: rgba(248,241,231,0.74);
}

/* GRID */

.benefits-grid{
  position: relative;
  z-index: 2;

  width: 100%;
  max-width: 1280px;

  margin: 0 auto;

  display: grid;
  grid-template-columns: repeat(4, minmax(0,1fr));

  justify-items: center;
  align-items: start;

  gap: 40px;
}

/* BENEFIT */

.benefit{
  width: 100%;

  display: flex;
  flex-direction: column;
  align-items: center;

  text-align: center;

  padding: 20px 12px;
}

/* SEAL */

.seal{
  width: 140px;
  height: 140px;

  margin-bottom: 30px;

  filter:
    drop-shadow(0 12px 28px rgba(0,0,0,0.35));

  transition:
    transform 0.45s cubic-bezier(0.2,0.8,0.2,1);
}

.benefit:hover .seal{
  transform:
    rotate(-6deg)
    scale(1.06);
}

/* TEXT */

.benefit-name{
  margin-bottom: 14px;

  font-family: "Italiana", serif;
  font-size: 30px;
  line-height: 1.1;

  color: #F8F1E7;
}

.benefit-desc{
  max-width: 22ch;

  margin: 0 auto;

  font-family: "Cormorant Garamond", serif;
  font-style: italic;
  font-size: 17px;
  line-height: 1.6;

  color: rgba(248,241,231,0.78);
}

/* REVEAL */

.reveal{
  opacity: 0;

  transform: translateY(30px);

  transition:
    opacity 0.9s cubic-bezier(0.2,0.8,0.2,1),
    transform 0.9s cubic-bezier(0.2,0.8,0.2,1);
}

.reveal.visible{
  opacity: 1;
  transform: translateY(0);
}

/* TABLET */

@media (max-width: 999px){

  .benefits-grid{
    grid-template-columns: repeat(2, minmax(0,1fr));

    gap: 30px;
  }

}

/* MOBILE */

@media (max-width: 600px){

  .section.benefits{
    padding: 90px 20px;
  }

  .benefits-grid{
    grid-template-columns: repeat(2, minmax(0,1fr));

    gap: 20px;
  }

  .seal{
    width: 110px;
    height: 110px;
  }

  .benefit-name{
    font-size: 22px;
  }

  .benefit-desc{
    font-size: 15px;
  }

}

</style>

<script>

document.addEventListener("DOMContentLoaded", () => {

  const reveals = document.querySelectorAll(".reveal");

  const observer = new IntersectionObserver((entries) => {

    entries.forEach((entry, index) => {

      if (entry.isIntersecting) {

        setTimeout(() => {
          entry.target.classList.add("visible");
        }, index * 120);

      }

    });

  }, {
    threshold: 0.12
  });

  reveals.forEach(el => observer.observe(el));

});

</script>