<section class="luxury-hero" id="luxury-hero">
  <div class="hero-container">
    <div class="hero-content">
      <h1 class="hero-title">{{ section.settings.headline }}</h1>
      <p class="hero-subtitle">{{ section.settings.subheadline }}</p>
      <a href="{{ section.settings.cta_link }}" class="hero-cta">{{ section.settings.cta_text }}</a>
      <div class="hero-stats">
        <div class="stat"><span class="stat-number">{{ section.settings.stat_1_number }}</span><p>{{ section.settings.stat_1_label }}</p></div>
        <div class="stat"><span class="stat-number">{{ section.settings.stat_2_number }}</span><p>{{ section.settings.stat_2_label }}</p></div>
        <div class="stat"><span class="stat-number">{{ section.settings.stat_3_number }}</span><p>{{ section.settings.stat_3_label }}</p></div>
      </div>
    </div>

    <div class="hero-image-wrapper">
      {% if section.settings.hero_image %}
        <img src="{{ section.settings.hero_image | image_url: width: 600 }}" alt="{{ section.settings.headline }}" class="hero-image">
      {% else %}
        <div class="hero-image-placeholder">Product Image</div>
      {% endif %}
    </div>
  </div>
  <div class="hero-particles"></div>
</section>

<style>
  .luxury-hero {
    min-height: 100vh;
    background: linear-gradient(135deg, #E4D9EE 0%, #C9B8DC 100%);
    margin-top: 60px;
    display: flex;
    align-items: center;
    overflow: hidden;
    position: relative;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    padding: 80px 56px;
    align-items: center;
    z-index: 2;
    position: relative;
  }

  .hero-content {
    text-align: left;
  }

  .hero-title {
    font-family: "Italiana", serif;
    font-size: 72px;
    letter-spacing: 0.08em;
    color: #2A2438;
    margin: 0 0 20px 0;
    line-height: 1.1;
  }

  .hero-subtitle {
    font-family: "Cormorant Garamond", serif;
    font-size: 28px;
    color: #5B4A7A;
    margin: 0 0 40px 0;
    font-weight: 300;
  }

  .hero-cta {
    display: inline-block;
    padding: 16px 48px;
    background: #B8945A;
    color: white;
    text-decoration: none;
    font-size: 14px;
    letter-spacing: 0.15em;
    border: 2px solid #B8945A;
    transition: all 0.3s ease;
    margin-right: 20px;
  }

  .hero-cta:hover {
    background: transparent;
    color: #B8945A;
  }

  .hero-stats {
    display: flex;
    gap: 60px;
    margin-top: 60px;
  }

  .stat {
    text-align: left;
  }

  .stat-number {
    font-family: "Italiana", serif;
    font-size: 48px;
    color: #B8945A;
    display: block;
  }

  .stat p {
    font-size: 12px;
    color: #5B4A7A;
    margin: 5px 0 0 0;
    letter-spacing: 0.1em;
  }

  .hero-image-wrapper {
    aspect-ratio: 1;
    position: relative;
    overflow: hidden;
    border: 8px solid #B8945A;
    border-radius: 50%;
    box-shadow: inset 0 0 40px rgba(184, 148, 90, 0.2), 0 20px 60px rgba(0, 0, 0, 0.1);
    background: radial-gradient(circle at 30% 30%, rgba(248, 241, 231, 0.4), transparent);
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #FBF6EE, #EFE4D2);
    color: #8E7AAB;
    font-family: "Inter", sans-serif;
    font-size: 18px;
  }

  @media (max-width: 1000px) {
    .hero-container {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 60px 40px;
    }

    .hero-title {
      font-size: 54px;
    }

    .hero-stats {
      gap: 40px;
    }
  }

  @media (max-width: 768px) {
    .luxury-hero {
      margin-top: 60px;
      min-height: auto;
      padding: 40px 0;
    }

    .hero-container {
      padding: 40px 20px;
      gap: 30px;
    }

    .hero-title {
      font-size: 40px;
      line-height: 1.2;
    }

    .hero-subtitle {
      font-size: 18px;
      margin: 0 0 30px 0;
    }

    .hero-cta {
      margin-right: 0;
      margin-bottom: 30px;
      display: block;
      width: 100%;
      text-align: center;
      padding: 14px 32px;
      font-size: 12px;
    }

    .hero-stats {
      flex-direction: row;
      gap: 20px;
      margin-top: 30px;
    }

    .stat {
      text-align: left;
    }

    .stat-number {
      font-size: 36px;
    }

    .stat p {
      font-size: 10px;
    }

    .hero-image-wrapper {
      aspect-ratio: 3/4;
      max-width: 280px;
    }
  }

  @media (max-width: 480px) {
    .luxury-hero {
      margin-top: 50px;
    }

    .hero-container {
      padding: 30px 16px;
      gap: 24px;
    }

    .hero-title {
      font-size: 32px;
      margin: 0 0 15px 0;
    }

    .hero-subtitle {
      font-size: 16px;
      margin: 0 0 20px 0;
    }

    .hero-cta {
      padding: 12px 24px;
      font-size: 11px;
      margin-bottom: 24px;
    }

    .hero-stats {
      gap: 16px;
      margin-top: 24px;
    }

    .stat-number {
      font-size: 28px;
    }

    .stat p {
      font-size: 9px;
    }

    .hero-image-wrapper {
      aspect-ratio: 4/5;
      max-width: 200px;
      margin: 0 auto;
    }
  }
</style>

{% schema %}
{
  "name": "Luxury Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Royal Skincare Elegance"
    },
    {
      "type": "text",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Indulge in luxury"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    },
    {
      "type": "text",
      "id": "stat_1_number",
      "label": "Stat 1 Number",
      "default": "50%"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 Label",
      "default": "More Radiant"
    },
    {
      "type": "text",
      "id": "stat_2_number",
      "label": "Stat 2 Number",
      "default": "+7"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 Label",
      "default": "Days Glow"
    },
    {
      "type": "text",
      "id": "stat_3_number",
      "label": "Stat 3 Number",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 Label",
      "default": "Natural"
    }
  ]
}
{% endschema %}
