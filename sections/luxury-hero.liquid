    {
      "type": "text",
      "id": "stat_3_number",
      "label": "Stat 3 Number",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 Label",
      "default": "Natural"
