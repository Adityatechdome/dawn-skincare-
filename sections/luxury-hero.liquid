<section class="luxury-hero" id="luxury-hero">
  <div class="hero-container">
    <div class="hero-content">
      <h1 class="hero-title">{{ section.settings.headline }}</h1>
      <p class="hero-subtitle">{{ section.settings.subheadline }}</p>
      <a href="{{ section.settings.cta_link }}" class="hero-cta">{{ section.settings.cta_text }}</a>

      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number">{{ section.settings.stat_1_number }}</span>
          <p>{{ section.settings.stat_1_label }}</p>
        </div>
        <div class="stat">
          <span class="stat-number">{{ section.settings.stat_2_number }}</span>
          <p>{{ section.settings.stat_2_label }}</p>
        </div>
        <div class="stat">
          <span class="stat-number">{{ section.settings.stat_3_number }}</span>
          <p>{{ section.settings.stat_3_label }}</p>
        </div>
      </div>
    </div>

    <div class="hero-image-wrapper">
      {% if section.settings.hero_image %}
        <img src="{{ section.settings.hero_image | image_url: width: 600 }}" alt="{{ section.settings.headline }}" class="hero-image">
      {% else %}
        <div class="hero-image-placeholder">Product Image</div>
      {% endif %}
    </div>
  </div>
</section>

<style>
.luxury-hero {
  min-height: 100vh;
  background: linear-gradient(135deg, #E4D9EE 0%, #C9B8DC 100%);
  display: flex;
  align-items: center;
}

.hero-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  max-width: 1400px;
  margin: 0 auto;
  width: 100%;
  padding: 80px 60px;
}

.hero-title {
  font-size: 72px;
  margin-bottom: 20px;
}

.hero-subtitle {
  font-size: 24px;
  margin-bottom: 30px;
}

.hero-cta {
  display: inline-block;
  padding: 15px 50px;
  background: #B8945A;
  color: #fff;
  text-decoration: none;
  border: 2px solid #B8945A;
}

.hero-stats {
  display: flex;
  gap: 40px;
  margin-top: 40px;
}

.hero-image-wrapper {
  aspect-ratio: 1;
  border-radius: 50%;
  overflow: hidden;
}

.hero-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
</style>

{% schema %}
{
  "name": "Luxury Hero",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Royal Skincare Elegance"
    },
    {
      "type": "text",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Indulge in luxury"
    },

    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    },

    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "text",
      "id": "stat_1_number",
      "label": "Stat 1 Number",
      "default": "50%"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 Label",
      "default": "More Radiant"
    },
    {
      "type": "text",
      "id": "stat_2_number",
      "label": "Stat 2 Number",
      "default": "+7"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 Label",
      "default": "Days Glow"
    },
    {
      "type": "text",
      "id": "stat_3_number",
      "label": "Stat 3 Number",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 Label",
      "default": "Natural"
    },

    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Horizontal Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "button_padding_x",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Button Padding X",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Luxury Hero"
    }
  ]
}
{% endschema %}