{% schema %}
{
  "name": "Skin Concern Bundles",
  "tag": "section",
  "class": "skin-concern-bundles",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Bundles",
      "default": "SKINCARE FAVORITES"
    },
    {
      "type": "text",
      "id": "tag_header",
      "label": "Tag Header",
      "default": "WHAT’S YOUR SKIN CONCERNS?"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Label",
      "default": "SHOP ALL SKINCARE"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "concern_bundle",
      "name": "Skin Concern Bundle",
      "settings": [
        {
          "type": "text",
          "id": "tag_label",
          "label": "Tag Label",
          "default": "ANTI-AGING"
        },
        {
          "type": "image_picker",
          "id": "tag_img",
          "label": "Tag image"
        },
        {
          "type": "product",
          "id": "product_1",
          "label": "Product 1"
        },
        {
          "type": "product",
          "id": "product_2",
          "label": "Product 2"
        },
        {
          "type": "product",
          "id": "product_3",
          "label": "Product 3"
        }
      ]
    },
    {
      "type": "concern_product",
      "name": "Skin Concern product",
      "settings": [
        {
          "type": "text",
          "id": "tag_label",
          "label": "Tag Label",
          "default": "cleanser"
        },
        {
          "type": "product",
          "id": "product_1",
          "label": "Product 1"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Skin Concern Bundles",
      "category": "Products"
    }
  ]
}
{% endschema %}

<section class="skin-concern-bundles-section">
  <div class="bundle-display">
    <h3 class="bundle-heading">{{ section.settings.heading }}</h3>
    {% for block in section.blocks %}
      {% assign has_product = false %}

      {% for i in (1..3) %}
        {% capture product_key %}product_{{ i }}{% endcapture %}
        {% assign product = block.settings[product_key] %}
        {% if product != blank %}
          {% assign has_product = true %}
        {% endif %}
      {% endfor %}

      {% if has_product %}
        <div class="bundle-group" data-bundle="{{ block.id }}">
          <div class="product-grid swiper-container">
            <div class="swiper-wrapper">
              {% for i in (1..3) %}
                {% capture product_key %}product_{{ i }}{% endcapture %}
                {% assign product = block.settings[product_key] %}
                {% if product and product.featured_image != blank %}
                  <div class="swiper-slide">
                    {% render 'bundle-card', product: product %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="tag-section">
    <h3 class="tag-header">{{ section.settings.tag_header }}</h3>

    <div class="tag-selectors">
      <div class="tag-selector concern-bundle-tags">
        {% for block in section.blocks %}
          {% if block.type == 'concern_bundle' %}
            <button class="skin-tag" data-bundle="{{ block.id }}">
              {% if block.settings.tag_img %}
                <div class="tag-img">
                  <img src="{{ block.settings.tag_img | image_url: width: 400 }}">
                </div>
              {% endif %}
              {{ block.settings.tag_label }}
            </button>
          {% endif %}
        {% endfor %}
      </div>

      <!-- Tags for concern_product blocks -->
      <div class="tag-selector concern-product-tags">
        {% for block in section.blocks %}
          {% if block.type == 'concern_product' %}
            <button class="skin-tag" data-bundle="{{ block.id }}">
              {{ block.settings.tag_label }}
            </button>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {% if section.settings.cta_link != blank %}
      <div class="skin-concern-cta">
        <a href="{{ section.settings.cta_link }}">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .skin-concern-bundles-section {
    background: #eeeae1;
    text-align: center;
  }

  .bundle-display {
    padding: 100px 77px 0;
    overflow: hidden;
  }

  .bundle-heading {
    font-family: Poppins;
    font-weight: 300;
    font-size: 34px;
    line-height: 39.1px;
    letter-spacing: 0%;
    text-align: center;
    text-transform: uppercase;
    margin: 0 0 42px;
  }

  .bundle-display .bundle-group {
    display: none;
  }

  .bundle-display .bundle-group.active {
    display: block;
  }

  .product-grid .swiper-wrapper {
    max-width: fit-content;
    margin: 0 auto;
  }

  .product-grid .swiper-slide {
    width: fit-content !important;
  }

  .tag-section {
    padding: 100px 0 104px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .tag-header {
    font-family: Poppins;
    font-weight: 300;
    font-style: Light;
    font-size: 34px;
    line-height: 39.1px;
    letter-spacing: 0%;
    text-align: center;
    text-transform: uppercase;
    margin: 0 0 75px;
  }

  .tag-selectors {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 40px;
  }

  .concern-bundle-tags,
  .concern-product-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 15px;
    max-width: 700px;
  }

  .skin-tag {
    background: #fff;
    border: 1px solid #cccccc;
    border-radius: 25px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4px;
    padding: 5px 8px;
    font-family: Poppins;
    font-weight: 400;
    font-size: 14px;
    line-height: 16.8px;
    letter-spacing: 0%;
    text-align: center;
    cursor: pointer;
  }

  .tag-img {
    width: 32px;
    height: 32px;
  }

  .tag-img img {
    width: 100%;
    height: 100%;
  }

  .skin-concern-cta {
    background: #000;
    padding: 19px 33px;
    font-family: Poppins;
    font-weight: 500;
    font-size: 12px;
    line-height: 12px;
    letter-spacing: 0.8px;
    text-align: center;
    text-transform: uppercase;
    color: #fff;
    border-radius: 5px;
    margin: 74px auto 0;
    max-width: 200px;
  }

  .skin-concern-cta a {
    color: #fff;
  }

  @media (max-width: 600px) {
    .bundle-display {
      padding: 50px 0 0 20px;
    }

    .bundle-heading {
      font-weight: 300;
      font-size: 24px;
      line-height: 26.02px;
      letter-spacing: 0%;
      margin: 0 0 27px;
    }

    .tag-header {
      font-weight: 300;
      font-size: 24px;
      line-height: 39.1px;
      letter-spacing: 0%;
      margin: 0 0 50px;
    }

    .tag-section {
      padding: 100px 37px 11px;
    }

    .skin-concern-cta {
      padding: 18px 20px;
      margin: 40px auto 0;
      background: #333333;
      font-size: 18px;
      font-weight: 500;
      max-width: 250px;
    }
  }
</style>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const tags = document.querySelectorAll('.skin-tag');
    const bundles = document.querySelectorAll('.bundle-group');

    function showBundle(id) {
      bundles.forEach((group) => {
        group.classList.toggle('active', group.dataset.bundle === id);
      });
    }

    // Show first bundle by default
    if (bundles.length > 0) {
      showBundle(bundles[0].dataset.bundle);
    }

    tags.forEach((tag) => {
      tag.addEventListener('click', () => {
        showBundle(tag.dataset.bundle);
      });
    });

    // Initialize Swiper for each bundle
    document.querySelectorAll('.swiper-container').forEach((container) => {
      new Swiper(container, {
        slidesPerView: 'auto',
        spaceBetween: 10,
        loop: false,
        navigation: false,
      });
    });
  });
</script>
