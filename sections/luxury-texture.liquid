<section id="texture-{{ section.id }}" class="texture-section">

  <div class="texture-inner">

    {% if section.settings.show_eyebrow %}
      <div class="texture-eyebrow reveal">
        <span>{{ section.settings.eyebrow_text }}</span>
      </div>
    {% endif %}

    <h2 class="texture-headline reveal">
      {{ section.settings.headline_text }}
      <em>
        {{ section.settings.em_text }}
      </em>
    </h2>

    {% if section.settings.show_subtitle %}
      <p class="texture-subtitle reveal">
        {{ section.settings.subtitle_text }}
      </p>
    {% endif %}

    <!-- TOP GRID -->

    <div class="texture-grid">

      {% for block in section.blocks %}

        <div class="texture-card reveal">

          <div class="texture-media">

            {% if block.settings.video != blank %}

              {{
                block.settings.video
                | video_tag:
                  autoplay: true,
                  loop: true,
                  muted: true,
                  controls: false,
                  playsinline: true,
                  class: 'texture-video'
              }}

            {% elsif block.settings.image != blank %}

              <img
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.title }}"
                loading="lazy"
                width="1200"
                height="1400"
              >

            {% endif %}

          </div>

          <div class="texture-overlay"></div>

          <div class="texture-content">

            {% if block.settings.micro_text != blank %}
              <div class="texture-micro">
                {{ block.settings.micro_text }}
              </div>
            {% endif %}

            {% if block.settings.title != blank %}
              <h3>
                {{ block.settings.title }}
              </h3>
            {% endif %}

            {% if block.settings.description != blank %}
              <p>
                {{ block.settings.description }}
              </p>
            {% endif %}

          </div>

        </div>

      {% endfor %}

    </div>

  </div>

</section>

<style>

#texture-{{ section.id }}{
  position: relative;

  width: 100vw;
  max-width: 100vw;

  left: 50%;
  right: 50%;

  margin-left: -50vw;
  margin-right: -50vw;

  overflow: hidden;

  background: #3D3158;

  padding: 110px 32px;
}

#texture-{{ section.id }} *{
  box-sizing: border-box;
}

.texture-inner{
  position: relative;
  z-index: 2;

  width: 100%;
  max-width: 1440px;

  margin: 0 auto;
}

/* EYEBROW */

.texture-eyebrow{
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;

  margin-bottom: 28px;
}

.texture-eyebrow::before,
.texture-eyebrow::after{
  content: "";

  width: 36px;
  height: 1px;

  background: rgba(217,186,130,0.5);
}

.texture-eyebrow span{
  font-family: "Inter", sans-serif;
  font-size: 11px;
  font-weight: 500;

  letter-spacing: 0.32em;
  text-transform: uppercase;

  color: #D9BA82;
}

/* HEADLINE */

.texture-headline{
  margin: 0 auto 22px;

  max-width: 10ch;

  text-align: center;

  font-family: "Italiana", serif;
  font-size: clamp(54px, 8vw, 120px);
  line-height: 0.92;
  font-weight: 400;

  color: #F8F1E7;
}

.texture-headline em{
  display: block;

  margin-top: 8px;

  font-style: normal;
  font-family: "Cormorant Garamond", serif;
  font-style: italic;

  color: #D9BA82;
}

/* SUBTITLE */

.texture-subtitle{
  max-width: 700px;

  margin: 0 auto 70px;

  text-align: center;

  font-family: "Cormorant Garamond", serif;
  font-style: italic;
  font-size: 24px;
  line-height: 1.5;

  color: rgba(248,241,231,0.72);
}

/* GRID */

.texture-grid{
  display: grid;
  grid-template-columns: repeat(2, minmax(0,1fr));

  gap: 28px;
}

/* CARD */

.texture-card{
  position: relative;

  overflow: hidden;

  min-height: 720px;

  border-radius: 34px;

  background: rgba(255,255,255,0.04);

  border: 1px solid rgba(255,255,255,0.08);

  backdrop-filter: blur(16px);

  box-shadow:
    0 24px 80px rgba(0,0,0,0.22);

  transition:
    transform 0.5s cubic-bezier(0.2,0.8,0.2,1),
    box-shadow 0.5s cubic-bezier(0.2,0.8,0.2,1);
}

.texture-card:hover{
  transform: translateY(-6px);

  box-shadow:
    0 34px 100px rgba(0,0,0,0.32);
}

/* MEDIA */

.texture-media{
  position: absolute;
  inset: 0;
}

.texture-media img,
.texture-media video{
  width: 100%;
  height: 100%;

  object-fit: cover;

  display: block;

  transition:
    transform 1.2s cubic-bezier(0.2,0.8,0.2,1);
}

.texture-card:hover img,
.texture-card:hover video{
  transform: scale(1.04);
}

/* OVERLAY */

.texture-overlay{
  position: absolute;
  inset: 0;

  background:
    linear-gradient(
      180deg,
      rgba(0,0,0,0.02) 0%,
      rgba(0,0,0,0.14) 40%,
      rgba(15,10,20,0.82) 100%
    );
}

/* CONTENT */

.texture-content{
  position: absolute;

  left: 0;
  right: 0;
  bottom: 0;

  z-index: 3;

  padding: 40px;
}

.texture-micro{
  margin-bottom: 14px;

  font-family: "JetBrains Mono", monospace;
  font-size: 10px;

  letter-spacing: 0.28em;
  text-transform: uppercase;

  color: rgba(217,186,130,0.82);
}

.texture-content h3{
  margin: 0 0 14px;

  font-family: "Italiana", serif;
  font-size: clamp(34px, 4vw, 52px);
  line-height: 1;

  color: #F8F1E7;
}

.texture-content p{
  margin: 0;

  max-width: 28ch;

  font-family: "Cormorant Garamond", serif;
  font-style: italic;
  font-size: 22px;
  line-height: 1.5;

  color: rgba(248,241,231,0.75);
}

/* REVEAL */

.reveal{
  opacity: 0;

  transform: translateY(40px);

  animation:
    textureReveal 1s cubic-bezier(0.2,0.8,0.2,1) forwards;
}

@keyframes textureReveal{
  to{
    opacity: 1;
    transform: translateY(0);
  }
}

/* RESPONSIVE */

@media screen and (max-width: 1100px){

  .texture-grid{
    grid-template-columns: 1fr;
  }

  .texture-card{
    min-height: 680px;
  }

}

@media screen and (max-width: 700px){

  #texture-{{ section.id }}{
    padding: 90px 20px;
  }

  .texture-headline{
    max-width: 100%;
  }

  .texture-subtitle{
    font-size: 20px;

    margin-bottom: 50px;
  }

  .texture-grid{
    gap: 20px;
  }

  .texture-card{
    min-height: 520px;

    border-radius: 26px;
  }

  .texture-content{
    padding: 26px;
  }

  .texture-content h3{
    font-size: 34px;
  }

  .texture-content p{
    font-size: 18px;
  }

}

@media screen and (max-width: 480px){

  #texture-{{ section.id }}{
    padding: 90px 16px;
  }

  .texture-card{
    min-height: 460px;
  }

  /* HIDE TEXT ON MOBILE */

  .texture-micro,
  .texture-content h3,
  .texture-content p{
    display: none;
  }

  .texture-content{
    padding: 0;
  }

}

</style>