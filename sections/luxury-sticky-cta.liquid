<section
  id="sticky-cta-{{ section.id }}"
  class="dawn-sticky-cta"
  role="region"
  aria-label="Promotion"
>

  <div class="sticky-cta-text">

    <strong>
      {{ section.settings.offer_text }}
    </strong>

    <span>
      · {{ section.settings.offer_subtext }}
    </span>

  </div>

  <button
    class="sticky-cta-button"
    type="button"
    aria-label="Add product to cart"
    data-variant-id="{{ all_products[section.settings.cta_product].selected_or_first_available_variant.id }}"
  >
    {{ section.settings.button_text }}
  </button>

</section>

<style>

#sticky-cta-{{ section.id }}{
  position: fixed;

  bottom: 24px;
  left: 50%;

  transform:
    translateX(-50%)
    translateY(120%);

  z-index: 90;

  display: inline-flex;
  align-items: center;
  gap: 18px;

  padding: 12px 14px 12px 22px;

  border-radius: 999px;

  background: #2A2438;

  color: #F8F1E7;

  box-shadow:
    0 20px 50px -12px rgba(0,0,0,0.4);

  transition:
    transform 0.5s cubic-bezier(0.2,0.8,0.2,1);

  max-width: calc(100vw - 32px);
}

#sticky-cta-{{ section.id }}.show{
  transform:
    translateX(-50%)
    translateY(0);
}

#sticky-cta-{{ section.id }} *{
  box-sizing: border-box;
}

/* TEXT */

.sticky-cta-text{
  display: flex;
  align-items: center;
  gap: 6px;

  white-space: nowrap;
}

.sticky-cta-text strong{
  font-family: "Italiana", serif;
  font-style: normal;
  font-weight: 400;
  font-size: 20px;

  letter-spacing: 0.05em;

  color: #D9BA82;
}

.sticky-cta-text span{
  font-family: "Cormorant Garamond", serif;
  font-style: italic;
  font-size: 15px;
  line-height: 1;

  color: #F8F1E7;
}

/* BUTTON */

.sticky-cta-button{
  appearance: none;
  border: none;
  outline: none;

  cursor: pointer;

  padding: 12px 20px;

  border-radius: 999px;

  background: #D9BA82;

  color: #2A2438;

  font-family: "Inter", sans-serif;
  font-size: 11px;
  font-weight: 500;

  letter-spacing: 0.20em;
  text-transform: uppercase;

  transition:
    background 0.2s ease,
    transform 0.2s ease;
}

.sticky-cta-button:hover{
  background: #F8F1E7;
}

/* RESPONSIVE */

@media screen and (max-width: 600px){

  #sticky-cta-{{ section.id }}{
    padding: 10px;
  }

  .sticky-cta-text{
    display: none;
  }

  .sticky-cta-button{
    padding: 12px 18px;

    font-size: 10px;
  }

}

/* REDUCE MOTION */

@media (prefers-reduced-motion: reduce){

  #sticky-cta-{{ section.id }}{
    transition: none;
  }

}

</style>

<script>

(function(){

  const stickyCTA =
    document.getElementById(
      'sticky-cta-{{ section.id }}'
    );

  const button =
    stickyCTA.querySelector(
      '.sticky-cta-button'
    );

  function toggleStickyCTA(){

    const threshold =
      window.innerHeight * 0.8;

    if(window.scrollY > threshold){

      stickyCTA.classList.add('show');

    }else{

      stickyCTA.classList.remove('show');

    }

  }

  window.addEventListener(
    'scroll',
    toggleStickyCTA,
    { passive: true }
  );

  toggleStickyCTA();

  button.addEventListener('click', async function(){

    const variantId =
      this.dataset.variantId;

    if(!variantId) return;

    const originalText =
      this.innerHTML;

    this.innerHTML =
      'ADDING...';

    try{

      await fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          items: [
            {
              id: variantId,
              quantity: 1
            }
          ]
        })
      });

      this.innerHTML =
        'ADDED ✓';

      document.dispatchEvent(
        new CustomEvent(
          'cart:refresh',
          { bubbles: true }
        )
      );

      const cartDrawer =
        document.querySelector(
          'cart-drawer'
        );

      if(cartDrawer && typeof cartDrawer.open === 'function'){

        cartDrawer.open();

      }

      setTimeout(() => {

        this.innerHTML =
          originalText;

      }, 2000);

    }catch(error){

      console.error(error);

      this.innerHTML =
        'TRY AGAIN';

      setTimeout(() => {

        this.innerHTML =
          originalText;

      }, 2000);

    }

  });

})();

</script>

{% schema %}
{
  "name": "Sticky Pricing CTA",

  "settings": [

    {
      "type": "text",
      "id": "offer_text",
      "label": "Offer Text",
      "default": "50% OFF"
    },

    {
      "type": "text",
      "id": "offer_subtext",
      "label": "Offer Subtext",
      "default": "Free BB Cream — today only"
    },

    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop the Glow"
    },

    {
      "type": "product",
      "id": "cta_product",
      "label": "CTA Product"
    }

  ],

  "presets": [
    {
      "name": "Sticky Pricing CTA"
    }
  ]
}
{% endschema %}