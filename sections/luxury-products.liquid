<link href="https://fonts.googleapis.com/css2?family=Italiana&family=Cormorant+Garamond:ital,wght@0,400;1,400&family=Pinyon+Script&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">

<section class="luxury-products">

  <div class="luxury-products-inner">

    <!-- LEFT IMAGE -->
    <div class="luxury-products-visual">

      <div class="luxury-product-shell">

        {% if section.settings.product_image != blank %}

          <img
            src="{{ section.settings.product_image | image_url: width: 1400 }}"
            alt="{{ section.settings.product_name }}"
            class="luxury-product-image"
            width="1400"
            height="1600"
          >

        {% else %}

          <div class="luxury-product-placeholder">

            <div class="luxury-product-placeholder-label">
              PRODUCT IMAGE · LUXURY SKINCARE<br>
              editorial lighting · premium packaging
            </div>

          </div>

        {% endif %}

      </div>

    </div>

    <!-- RIGHT CONTENT -->
    <div class="luxury-products-copy">

      <!-- EYEBROW -->
      <div class="luxury-products-eyebrow">
        Signature Collection
      </div>

      <!-- TITLE -->
      <h2 class="luxury-products-title">
        {{ section.settings.section_title }}
      </h2>

      <!-- SUBTITLE -->
      <div class="luxury-products-subtitle">
        {{ section.settings.section_subtitle }}
      </div>

      <!-- PRODUCT CARD -->
      <div class="luxury-product-card">

        <div class="luxury-product-top">

          <h3 class="luxury-product-name">
            {{ section.settings.product_name }}
          </h3>

        </div>

        <div class="luxury-product-description">
          {{ section.settings.product_description }}
        </div>

        <!-- CTA + PRICE -->
        <div class="luxury-product-bottom">

          <button
            class="luxury-product-btn"
            type="button"
            data-variant-id="{{ all_products[section.settings.cta_product].selected_or_first_available_variant.id }}"
          >

            <span>
              {{ section.settings.cta_text }}
            </span>

            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
              <path d="M12 2L13.8 8.2L20 10L13.8 11.8L12 18L10.2 11.8L4 10L10.2 8.2L12 2Z" fill="#D9BA82"/>
            </svg>

          </button>

          <div class="luxury-product-price">
            {{ section.settings.product_price }}
          </div>

        </div>

      </div>

    </div>

  </div>

</section>

<style>
.luxury-products {
  position: relative;
  overflow: hidden;

  padding: 140px 56px;

  background:
    radial-gradient(ellipse at 20% 10%, rgba(228,217,238,0.55) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 80%, rgba(232,201,204,0.32) 0%, transparent 50%),
    radial-gradient(ellipse at 50% 50%, #FBF6EE, #F8F1E7 70%);
}

.luxury-products-inner {
  max-width: 1440px;
  margin: 0 auto;

  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 100px;
  align-items: center;
}

/* LEFT IMAGE */

.luxury-products-visual {
  position: relative;
}

.luxury-product-shell {
  position: relative;

  width: 100%;
  aspect-ratio: 4 / 5;

  overflow: hidden;

  border-radius:
    50% 50% 12px 12px /
    14% 14% 6% 6%;

  background:
    radial-gradient(
      ellipse at 50% 30%,
      rgba(255,255,255,0.4),
      transparent 60%
    ),
    linear-gradient(
      180deg,
      #E4D9EE 0%,
      #C9B8DC 60%,
      #8E7AAB 100%
    );

  box-shadow:
    inset 0 -40px 80px rgba(91,74,122,0.25),
    0 60px 120px -40px rgba(91,74,122,0.4);
}

.luxury-product-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.luxury-product-placeholder {
  width: 100%;
  height: 100%;

  display: flex;
  align-items: center;
  justify-content: center;

  padding: 40px;

  background:
    repeating-linear-gradient(
      45deg,
      rgba(184,148,90,0.06) 0 14px,
      rgba(184,148,90,0.12) 14px 28px
    ),
    linear-gradient(135deg, #E4D9EE, #EFE4D2);
}

.luxury-product-placeholder-label {
  max-width: 80%;

  padding: 10px 16px;

  border-radius: 4px;

  border: 1px solid rgba(184,148,90,0.4);

  background: rgba(248,241,231,0.88);

  text-align: center;

  font-family: "JetBrains Mono", monospace;
  font-size: 10px;
  line-height: 1.8;
  letter-spacing: 0.18em;
  text-transform: uppercase;

  color: #8C6F3F;
}

/* RIGHT */

.luxury-products-copy {
  position: relative;
}

.luxury-products-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 12px;

  margin-bottom: 30px;

  color: #8C6F3F;

  font-family: "Inter", sans-serif;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.32em;
  text-transform: uppercase;
}

.luxury-products-eyebrow::before {
  content: "";

  width: 28px;
  height: 1px;

  background: #B8945A;
}

.luxury-products-title {
  font-family: "Italiana", serif;
  font-size: clamp(54px, 7vw, 104px);
  font-weight: 400;
  line-height: 0.92;
  letter-spacing: -0.02em;

  color: #2A2438;

  margin-bottom: 32px;

  text-wrap: pretty;
}

.luxury-products-subtitle {
  max-width: 540px;

  margin-bottom: 52px;

  font-family: "Cormorant Garamond", serif;
  font-style: italic;
  font-size: 24px;
  line-height: 1.6;

  color: rgba(42,36,56,0.78);
}

/* CARD */

.luxury-product-card {
  padding: 42px;

  border-radius: 34px;

  border: 1px solid rgba(184,148,90,0.18);

  background: rgba(255,255,255,0.36);

  backdrop-filter: blur(10px);

  box-shadow:
    0 30px 80px rgba(91,74,122,0.08);
}

.luxury-product-top {
  margin-bottom: 28px;
}

.luxury-product-name {
  font-family: "Italiana", serif;
  font-size: 46px;
  line-height: 0.96;
  letter-spacing: -0.02em;

  color: #2A2438;
}

.luxury-product-description {
  margin-bottom: 38px;

  font-family: "Cormorant Garamond", serif;
  font-size: 23px;
  line-height: 1.7;

  color: rgba(42,36,56,0.78);
}

/* BOTTOM */

.luxury-product-bottom {
  display: flex;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
}

.luxury-product-btn {
  position: relative;

  display: inline-flex;
  align-items: center;
  gap: 10px;

  overflow: hidden;

  padding: 20px 36px;

  border-radius: 999px;

  border: none;
  outline: none;
  cursor: pointer;

  background: #2A2438;
  color: #F8F1E7;

  text-decoration: none;

  font-family: "Inter", sans-serif;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.24em;
  text-transform: uppercase;

  transition:
    all 0.3s cubic-bezier(0.2,0.8,0.2,1);

  box-shadow:
    0 12px 32px -16px rgba(42,36,56,0.4);
}

.luxury-product-btn::after {
  content: "";

  position: absolute;
  inset: 0;

  background:
    radial-gradient(
      circle at center,
      rgba(217,186,130,0.6) 0%,
      transparent 60%
    );

  opacity: 0;

  transition: 0.3s ease;
}

.luxury-product-btn:hover {
  background: #5B4A7A;

  transform: translateY(-2px);

  box-shadow:
    0 16px 40px -12px rgba(91,74,122,0.5);
}

.luxury-product-btn:hover::after {
  opacity: 1;
}

.luxury-product-price {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  padding: 12px 18px;

  border-radius: 999px;

  border: 1px solid rgba(184,148,90,0.26);

  background: rgba(255,255,255,0.5);

  font-family: "Inter", sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;

  color: #8C6F3F;
}

/* RESPONSIVE */

@media screen and (max-width: 1000px) {

  .luxury-products {
    padding: 110px 24px 70px;
  }

  .luxury-products-inner {
    grid-template-columns: 1fr;
    gap: 70px;
  }

  .luxury-products-copy {
    text-align: center;
  }

  .luxury-products-eyebrow {
    justify-content: center;
  }

  .luxury-products-eyebrow::after {
    content: "";

    width: 28px;
    height: 1px;

    background: #B8945A;
  }

  .luxury-products-subtitle {
    margin-left: auto;
    margin-right: auto;
  }

  .luxury-products-visual {
    max-width: 500px;
    margin: 0 auto;
  }

  .luxury-product-bottom {
    justify-content: center;
  }

}

@media screen and (max-width: 600px) {

  .luxury-product-card {
    padding: 30px;
  }

  .luxury-products-title {
    font-size: clamp(44px, 12vw, 68px);
  }

  .luxury-product-name {
    font-size: 38px;
  }

  .luxury-product-description {
    font-size: 21px;
  }

}
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {

  const productButton =
    document.querySelector('.luxury-product-btn');

  if(productButton){

    productButton.addEventListener('click', async function(e){

      e.preventDefault();

      const variantId =
        this.dataset.variantId;

      if(!variantId) return;

      const buttonText =
        this.querySelector('span');

      const originalText =
        buttonText.innerHTML;

      buttonText.innerHTML =
        'ADDING...';

      const formData = new FormData();

      formData.append('id', variantId);

      formData.append(
        'sections',
        'cart-drawer,cart-icon-bubble'
      );

      formData.append(
        'sections_url',
        window.location.pathname
      );

      try{

        const response = await fetch('/cart/add.js', {
          method: 'POST',
          body: formData
        });

        const result =
          await response.json();

        buttonText.innerHTML =
          'ADDED ✓';

        const cartDrawer =
          document.querySelector('cart-drawer');

        if(cartDrawer && cartDrawer.renderContents){

          cartDrawer.renderContents({
            sections: result.sections,
            id: result.id
          });

          setTimeout(() => {

            cartDrawer.open();

          }, 220);

        }

        setTimeout(() => {

          buttonText.innerHTML =
            originalText;

        }, 2000);

      }catch(error){

        console.error(error);

        buttonText.innerHTML =
          'TRY AGAIN';

        setTimeout(() => {

          buttonText.innerHTML =
            originalText;

        }, 2000);

      }

    });

  }

});
</script>

{% schema %}
{
  "name": "Luxury Products",
  "settings": [
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Our Signature Collection"
    },
    {
      "type": "text",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "Handpicked products for radiant, luxurious skin"
    },
    {
      "type": "header",
      "content": "Product Details"
    },
    {
      "type": "text",
      "id": "product_name",
      "label": "Product Name",
      "default": "Royal Cream Luxe"
    },
    {
      "type": "textarea",
      "id": "product_description",
      "label": "Product Description",
      "default": "Our signature cream infused with the finest botanicals. Whipped at low temperature, layered like petit fours. Experience luxury in every application."
    },
    {
      "type": "text",
      "id": "product_price",
      "label": "Product Price",
      "default": "$222"
    },
    {
      "type": "header",
      "content": "Media & CTA"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Image"
    },
    {
      "type": "url",
      "id": "product_link",
      "label": "Product Link"
    },
    {
      "type": "product",
      "id": "cta_product",
      "label": "CTA Product"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Shop Now"
    }
  ],
  "presets": [
    {
      "name": "Luxury Products"
    }
  ]
}
{% endschema %}