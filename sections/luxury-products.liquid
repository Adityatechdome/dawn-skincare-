<link href="https://fonts.googleapis.com/css2?family=Italiana&family=Cormorant+Garamond:ital,wght@0,400;1,400&family=Inter:wght@400;500&display=swap" rel="stylesheet">

<section class="luxury-products">

  <div class="luxury-products-inner">

    <!-- LEFT IMAGE -->
    <div class="luxury-products-visual">

      <div class="luxury-product-shell">

        {% if section.settings.product_image != blank %}

          <img
            src="{{ section.settings.product_image | image_url: width: 1200 }}"
            alt="{{ section.settings.product_name }}"
            class="luxury-product-image"
            width="1200"
            height="1500"
          >

        {% else %}

          <div class="luxury-product-placeholder">

            <div class="luxury-product-placeholder-label">
              PRODUCT IMAGE · LUXURY SKINCARE<br>
              editorial lighting · premium packaging
            </div>

          </div>

        {% endif %}

      </div>

    </div>

    <!-- RIGHT CONTENT -->
    <div class="luxury-products-copy">

      <div class="luxury-products-eyebrow">
        Signature Collection
      </div>

      <h2 class="luxury-products-title">
        {{ section.settings.section_title }}
      </h2>

      <p class="luxury-products-subtitle">
        {{ section.settings.section_subtitle }}
      </p>

      <div class="luxury-product-card">

        <h3 class="luxury-product-name">
          {{ section.settings.product_name }}
        </h3>

        <p class="luxury-product-description">
          {{ section.settings.product_description }}
        </p>

        <!-- BUTTON + PRICE -->
        <div class="luxury-product-bottom">

          <a
            href="{{ section.settings.product_link }}"
            class="luxury-product-btn"
          >

            <span>
              {{ section.settings.cta_text }}
            </span>

            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
              <path d="M12 2L13.8 8.2L20 10L13.8 11.8L12 18L10.2 11.8L4 10L10.2 8.2L12 2Z" fill="#D9BA82"/>
            </svg>

          </a>

          <div class="luxury-product-price">
            {{ section.settings.product_price }}
          </div>

        </div>

      </div>

    </div>

  </div>

</section>

<style>
.luxury-products {
  position: relative;
  overflow: hidden;

  padding: 120px 56px;

  background:
    radial-gradient(ellipse at 20% 10%, rgba(228, 217, 238, 0.45) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 80%, rgba(232, 201, 204, 0.25) 0%, transparent 50%),
    radial-gradient(ellipse at 50% 50%, #FBF6EE, #F8F1E7 70%);
}

.luxury-products-inner {
  max-width: 1440px;
  margin: 0 auto;

  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}

/* LEFT IMAGE */

.luxury-products-visual {
  position: relative;
}

.luxury-product-shell {
  position: relative;

  width: 100%;
  aspect-ratio: 4 / 5;

  overflow: hidden;

  border-radius:
    50% 50% 12px 12px /
    14% 14% 6% 6%;

  background:
    radial-gradient(ellipse at 50% 30%, rgba(255,255,255,0.4), transparent 60%),
    linear-gradient(180deg, #E4D9EE 0%, #C9B8DC 60%, #8E7AAB 100%);

  box-shadow:
    inset 0 -40px 80px rgba(91,74,122,0.25),
    0 60px 120px -40px rgba(91,74,122,0.4);
}

.luxury-product-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.luxury-product-placeholder {
  width: 100%;
  height: 100%;

  display: flex;
  align-items: center;
  justify-content: center;

  padding: 40px;

  background:
    repeating-linear-gradient(
      45deg,
      rgba(184,148,90,0.06) 0 14px,
      rgba(184,148,90,0.12) 14px 28px
    ),
    linear-gradient(135deg, #E4D9EE, #EFE4D2);
}

.luxury-product-placeholder-label {
  max-width: 80%;

  padding: 8px 14px;

  border-radius: 2px;
  border: 1px solid rgba(184,148,90,0.4);

  background: rgba(248,241,231,0.85);

  text-align: center;

  font-family: "JetBrains Mono", monospace;
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  line-height: 1.8;

  color: #8C6F3F;
}

/* RIGHT CONTENT */

.luxury-products-copy {
  position: relative;
}

.luxury-products-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 12px;

  margin-bottom: 24px;

  position: relative;

  color: #8C6F3F;

  font-family: "Inter", sans-serif;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.32em;
  text-transform: uppercase;
}

.luxury-products-eyebrow::before {
  content: "";
  width: 28px;
  height: 1px;
  background: #B8945A;
}

.luxury-products-title {
  font-family: "Italiana", serif;
  font-size: clamp(48px, 6vw, 88px);
  line-height: 0.95;
  letter-spacing: -0.02em;

  color: #2A2438;

  margin-bottom: 26px;
}

.luxury-products-subtitle {
  max-width: 520px;

  margin-bottom: 50px;

  font-family: "Cormorant Garamond", serif;
  font-style: italic;
  font-size: 24px;
  line-height: 1.5;

  color: rgba(42,36,56,0.78);
}

/* CARD */

.luxury-product-card {
  padding: 40px;

  border: 1px solid rgba(184,148,90,0.18);
  border-radius: 32px;

  backdrop-filter: blur(10px);

  background: rgba(255,255,255,0.35);

  box-shadow:
    0 30px 80px rgba(91,74,122,0.08);
}

.luxury-product-name {
  font-family: "Italiana", serif;
  font-size: 42px;
  line-height: 1;

  color: #2A2438;

  margin-bottom: 24px;
}

.luxury-product-description {
  margin-bottom: 34px;

  font-family: "Cormorant Garamond", serif;
  font-size: 22px;
  line-height: 1.7;

  color: rgba(42,36,56,0.78);
}

/* BOTTOM */

.luxury-product-bottom {
  display: flex;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
}

.luxury-product-btn {
  position: relative;

  display: inline-flex;
  align-items: center;
  gap: 10px;

  padding: 18px 34px;

  border-radius: 999px;

  overflow: hidden;

  background: #2A2438;
  color: #F8F1E7;

  text-decoration: none;

  font-family: "Inter", sans-serif;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.24em;
  text-transform: uppercase;

  transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);

  box-shadow:
    0 12px 32px -16px rgba(42,36,56,0.4);
}

.luxury-product-btn::after {
  content: "";

  position: absolute;
  inset: 0;

  background:
    radial-gradient(circle at center,
    rgba(217,186,130,0.5) 0%,
    transparent 60%);

  opacity: 0;

  transition: 0.3s ease;
}

.luxury-product-btn:hover {
  background: #5B4A7A;

  transform: translateY(-2px);

  box-shadow:
    0 16px 40px -12px rgba(91,74,122,0.45);
}

.luxury-product-btn:hover::after {
  opacity: 1;
}

.luxury-product-price {
  font-family: "Inter", sans-serif;
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;

  color: #8C6F3F;

  padding: 10px 14px;

  border-radius: 999px;

  border: 1px solid rgba(184,148,90,0.24);

  background: rgba(255,255,255,0.45);
}

/* RESPONSIVE */

@media screen and (max-width: 1000px) {

  .luxury-products {
    padding: 100px 24px;
  }

  .luxury-products-inner {
    grid-template-columns: 1fr;
    gap: 60px;
  }

  .luxury-products-copy {
    text-align: center;
  }

  .luxury-products-eyebrow {
    justify-content: center;
  }

  .luxury-products-eyebrow::after {
    content: "";
    width: 28px;
    height: 1px;
    background: #B8945A;
  }

  .luxury-products-subtitle {
    margin-left: auto;
    margin-right: auto;
  }

  .luxury-products-visual {
    max-width: 460px;
    margin: 0 auto;
  }

  .luxury-product-bottom {
    justify-content: center;
  }

}

@media screen and (max-width: 600px) {

  .luxury-product-card {
    padding: 28px;
  }

  .luxury-product-name {
    font-size: 34px;
  }

  .luxury-product-description {
    font-size: 20px;
  }

}
</style>

{% schema %}
{
  "name": "Luxury Products",
  "settings": [
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Our Signature Collection"
    },
    {
      "type": "text",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "Handpicked products for radiant, luxurious skin"
    },
    {
      "type": "header",
      "content": "Product Details"
    },
    {
      "type": "text",
      "id": "product_name",
      "label": "Product Name",
      "default": "Royal Cream Luxe"
    },
    {
      "type": "textarea",
      "id": "product_description",
      "label": "Product Description",
      "default": "Our signature cream infused with the finest botanicals. Whipped at low temperature, layered like petit fours. Experience luxury in every application."
    },
    {
      "type": "text",
      "id": "product_price",
      "label": "Product Price",
      "default": "$222"
    },
    {
      "type": "header",
      "content": "Media & CTA"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Image"
    },
    {
      "type": "url",
      "id": "product_link",
      "label": "Product Link"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Shop Now"
    }
  ],
  "presets": [
    {
      "name": "Luxury Products"
    }
  ]
}
{% endschema %}