<link href="https://fonts.googleapis.com/css2?family=Italiana&family=Cormorant+Garamond:ital,wght@0,400;1,400&family=Pinyon+Script&family=Inter:wght@400;500&display=swap" rel="stylesheet">

<section class="luxury-products">

  <div class="luxury-products-inner">

    <!-- LEFT -->
    <div class="luxury-products-copy">

      <div class="luxury-products-eyebrow">
        Signature Collection
      </div>

      <h2 class="luxury-products-title">
        {{ section.settings.section_title }}
      </h2>

      <p class="luxury-products-subtitle">
        {{ section.settings.section_subtitle }}
      </p>

      <div class="luxury-product-card">

        <div class="luxury-product-meta">

          <h3>
            {{ section.settings.product_name }}
          </h3>

          <div class="luxury-product-price">
            {{ section.settings.product_price }}
          </div>

        </div>

        <p class="luxury-product-description">
          {{ section.settings.product_description }}
        </p>

        <a
          href="{{ section.settings.product_link }}"
          class="luxury-product-btn"
        >

          <span>
            {{ section.settings.cta_text }}
          </span>

          <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
            <path d="M12 2L13.8 8.2L20 10L13.8 11.8L12 18L10.2 11.8L4 10L10.2 8.2L12 2Z" fill="#D9BA82"/>
          </svg>

        </a>

      </div>

    </div>

    <!-- RIGHT -->
    <div class="luxury-products-visual">

      <div class="luxury-product-shell">

        {% if section.settings.product_image != blank %}

          <img
            src="{{ section.settings.product_image | image_url: width: 1200 }}"
            alt="{{ section.settings.product_name }}"
            class="luxury-product-image"
            width="1200"
            height="1500"
          >

        {% else %}

          <div class="luxury-product-placeholder">

            <div class="luxury-product-placeholder-label">
              PRODUCT IMAGE · LUXURY SKINCARE<br>
              editorial lighting · premium packaging
            </div>

          </div>

        {% endif %}

      </div>

    </div>

  </div>

</section>

<style>
.luxury-products {
  position: relative;
  overflow: hidden;

  padding: 120px 56px;

  background:
    radial-gradient(ellipse at 20% 10%, rgba(228, 217, 238, 0.45) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 80%, rgba(232, 201, 204, 0.25) 0%, transparent 50%),
    radial-gradient(ellipse at 50% 50%, #FBF6EE, #F8F1E7 70%);
}

.luxury-products-inner {
  max-width: 1440px;
  margin: 0 auto;

  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}

<!-- LEFT IMAGE -->
<div class="luxury-products-visual">

  <div class="luxury-product-shell">

    {% if section.settings.product_image != blank %}

      <img
        src="{{ section.settings.product_image | image_url: width: 1200 }}"
        alt="{{ section.settings.product_name }}"
        class="luxury-product-image"
        width="1200"
        height="1500"
      >

    {% else %}

      <div class="luxury-product-placeholder">

        <div class="luxury-product-placeholder-label">
          PRODUCT IMAGE · LUXURY SKINCARE<br>
          editorial lighting · premium packaging
        </div>

      </div>

    {% endif %}

  </div>

</div>

<!-- RIGHT CONTENT -->
<div class="luxury-products-copy">

  <div class="luxury-products-eyebrow">
    Signature Collection
  </div>

  <h2 class="luxury-products-title">
    {{ section.settings.section_title }}
  </h2>

  <p class="luxury-products-subtitle">
    {{ section.settings.section_subtitle }}
  </p>

  <div class="luxury-product-card">

    <h3 class="luxury-product-name">
      {{ section.settings.product_name }}
    </h3>

    <p class="luxury-product-description">
      {{ section.settings.product_description }}
    </p>

    <!-- BUTTON + PRICE -->
    <div class="luxury-product-bottom">

      <a
        href="{{ section.settings.product_link }}"
        class="luxury-product-btn"
      >

        <span>
          {{ section.settings.cta_text }}
        </span>

        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
          <path d="M12 2L13.8 8.2L20 10L13.8 11.8L12 18L10.2 11.8L4 10L10.2 8.2L12 2Z" fill="#D9BA82"/>
        </svg>

      </a>

      <div class="luxury-product-price">
        {{ section.settings.product_price }}
      </div>

    </div>

  </div>

</div>
}

/* RESPONSIVE */

@media screen and (max-width: 1000px) {

  .luxury-products {
    padding: 100px 24px;
  }

  .luxury-products-inner {
    grid-template-columns: 1fr;
    gap: 60px;
  }

  .luxury-products-copy {
    text-align: center;
  }

  .luxury-products-eyebrow {
    justify-content: center;
  }

  .luxury-products-eyebrow::after {
    content: "";
    width: 28px;
    height: 1px;
    background: #B8945A;
  }

  .luxury-products-subtitle {
    margin-left: auto;
    margin-right: auto;
  }

  .luxury-products-visual {
    max-width: 460px;
    margin: 0 auto;
  }

  .luxury-product-meta {
    flex-direction: column;
    align-items: center;
  }

}

@media screen and (max-width: 600px) {

  .luxury-product-card {
    padding: 28px;
  }

  .luxury-product-meta h3 {
    font-size: 34px;
  }

  .luxury-product-description {
    font-size: 20px;
  }

}
</style>

{% schema %}
{
  "name": "Luxury Products",
  "settings": [
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Our Signature Collection"
    },
    {
      "type": "text",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "Handpicked products for radiant, luxurious skin"
    },
    {
      "type": "header",
      "content": "Product Details"
    },
    {
      "type": "text",
      "id": "product_name",
      "label": "Product Name",
      "default": "Royal Cream Luxe"
    },
    {
      "type": "textarea",
      "id": "product_description",
      "label": "Product Description",
      "default": "Our signature cream infused with the finest botanicals. Whipped at low temperature, layered like petit fours. Experience luxury in every application."
    },
    {
      "type": "text",
      "id": "product_price",
      "label": "Product Price",
      "default": "$222"
    },
    {
      "type": "header",
      "content": "Media & CTA"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Image"
    },
    {
      "type": "url",
      "id": "product_link",
      "label": "Product Link"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Shop Now"
    }
  ],
  "presets": [
    {
      "name": "Luxury Products"
    }
  ]
}
{% endschema %}