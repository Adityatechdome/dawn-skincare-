{% schema %}
{
  "name": "Dawn Feature",
  "tag": "section",
  "class": "dawn-feature",
  "settings": [
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Skin Care"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Potent Solutions for Demanding Skin"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover products tailored for mature skin and urban lifestyles, offering daily hydration and the added advantage of powerful vitamins and antioxidants."
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Label",
      "default": "Read More →"
    }
  ],
  "presets": [
    {
      "name": "Dawn Feature",
      "category": "Image"
    }
  ]
}
{% endschema %}

<section class="dawn-feature-section">
  <div class="feature-wrapper">
    <div class="feature-image">
      {% if section.settings.product_image %}
        <img
          src="{{ section.settings.product_image | image_url: width: 600 }}"
          alt="Featured Product"
          loading="lazy"
        >
      {% endif %}
    </div>

    <div class="feature-content">
      <div class="feature-text">
        <h2 class="feature-heading">{{ section.settings.heading }}</h2>
        <h3 class="feature-subheading">{{ section.settings.subheading }}</h3>
        <p class="feature-description">{{ section.settings.description }}</p>
      </div>
      <a href="{{ section.settings.cta_link }}" class="feature-cta"
        ><span>Readmore</span>
        <span>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <g clip-path="url(#clip0_192_139)">
            <path d="M3.75 12H20.25" stroke="#333333" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M13.5 5.25L20.25 12L13.5 18.75" stroke="#333333" stroke-linecap="round" stroke-linejoin="round"/>
            </g>
            <defs>
            <clipPath id="clip0_192_139">
            <rect width="24" height="24" fill="white"/>
            </clipPath>
            </defs>
          </svg></span
      ></a>
    </div>
  </div>
</section>

<style>
  .dawn-feature-section {
    background-color: #eeeae1;
    padding: 150px 80px;
  }

  .feature-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 1400px;
    margin: 0 auto;
    gap: 116px;
    flex-wrap: wrap;
  }

  .feature-image {
    width: 562px;
    height: 532px;
  }

  .feature-image img {
    max-width: 100%;
    height: auto;
  }

  .feature-content {
    max-width: 500px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 53px;
  }

  .feature-heading {
    font-family: Poppins;
    font-weight: 400;
    font-size: 14px;
    line-height: 23.8px;
    letter-spacing: -1%;
    color: #333333;
    margin: 0 0 5px;
    text-transform: capitalize;
  }

  .feature-subheading {
    font-family: Valky;
    font-weight: 400;
    font-size: 40px;
    line-height: 50px;
    letter-spacing: 0%;
    color: #333333;
    margin: 0 0 20px;
    text-transform: capitalize;
  }

  .feature-description {
    font-family: Poppins;
    font-weight: 400;
    font-size: 16px;
    line-height: 27px;
    letter-spacing: 0%;
    color: #333333;
    margin: 0;
    text-transform: normal;
  }

  .feature-cta {
    display: inline-block;
    max-width: fit-content;
    padding: 19px 23px;
    display: flex;
    justify-content: center;
    gap: 75px;
    font-family: Poppins;
    font-weight: 400;
    font-size: 14px;
    line-height: 23.8px;
    letter-spacing: -1%;
    border: 1px solid #cdcbc0;
    color: #333333;
  }

  @media (max-width: 1338px) and (min-width: 1176px) {
    .feature-image {
      width: 400px;
      height: auto;
    }
  }

  @media (max-width: 1176px) and (min-width: 1126px) {
    .feature-image {
      width: 350px;
      height: auto;
    }
  }

  @media (max-width: 1125px) and (min-width: 1077px) {
    .feature-image {
      width: 300px;
      height: auto;
    }
  }

  @media (max-width: 1076px) and (min-width: 901px) {
    .feature-image {
      width: 400px;
      height: auto;
    }

    .feature-wrapper{
      gap: 80px;
    }

    .feature-content{
      max-width: 400px;
    }
  }

  @media (max-width: 900px) {
    .dawn-feature-section {
      padding: 50px 20px 70px;
    }

    .feature-image {
      width: 100%;
      height: auto;
    }

    .feature-wrapper {
      flex-direction: column;
      gap: 30px;
    }

    .feature-description {
      font-size: 14px;
      line-height: 27px;
    }

    .feature-content {
      gap: 30px;
    }

    .feature-text {
      max-width: 100%;
    }
  }
</style>
