{% schema %}
{
  "name": "Natural Skincare Hero",
  "tag": "section",
  "class": "natural-skincare-hero",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Nature’s genius is limitless; we transform it into indulgent rituals crafted for exceptional skin"
    },
    {
      "type": "text",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "THE FUTURE OF NATURAL SKINCARE"
    }
  ],
  "presets": [
    {
      "name": "Natural Skincare Hero",
      "category": "Text"
    }
  ]
}
{% endschema %}

<section class="natural-skincare-hero-section">
  <div class="hero-text-wrapper">
    <h2 class="hero-headline">
      {{ section.settings.headline }}
    </h2>
    <h3 class="hero-subheadline">
      {{ section.settings.subheadline }}
    </h3>
  </div>
</section>
<style>
  .natural-skincare-hero-section {
    padding: 100px 40px;
    text-align: center;
    background: radial-gradient(#ccb8ff, #a186e9);
  }

  .hero-text-wrapper {
    max-width:1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .natural-skincare-hero-section .hero-headline {
    font-family: "Zapf Humanist 601";
    font-weight: 400;
    font-size: 40px;
    line-height: 40px;
    letter-spacing: 0%;
    text-align: center;
    margin: 0 0 50px;
    color: #333333;
    text-transform: none;
    max-width: 100%;
  }

  .natural-skincare-hero-section .hero-subheadline {
    font-family: Arimo Hebrew Subset;
    font-weight: 300;
    font-size: 14px;
    line-height: 23.8px;
    letter-spacing: -1%;
    text-align: center;
    margin: 0;
    color: #333333;
  }

  @media (max-width: 1000px){
    .natural-skincare-hero-section{
      padding: 80px 20px;
    }

    .hero-text-wrapper{
      max-width: 800px;
    }

    .natural-skincare-hero-section .hero-headline{
      font-family: Recoleta;
      font-size: 34px;
    }

    .natural-skincare-hero-section .hero-subheadline{
      font-family:Poppins;  
      font-weight: 400;
    }
  }
</style>
