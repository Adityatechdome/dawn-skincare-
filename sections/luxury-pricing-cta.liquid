# luxury-pricing-cta.liquid

```liquid
<section id="final-cta-{{ section.id }}" class="final-cta-section">

  <!-- STAGE GLOW -->

  <div class="final-cta-table"></div>

  <div class="final-cta-inner">

    <!-- EYEBROW -->

    <div class="final-cta-eyebrow reveal">
      <span>{{ section.settings.eyebrow }}</span>
    </div>

    <!-- TITLE -->

    <h2 class="final-cta-title reveal">

      {{ section.settings.title_line_1 }}

      <em>
        {{ section.settings.title_line_2 }}
      </em>

    </h2>

    <!-- SUBTITLE -->

    <p class="final-cta-subline reveal">
      {{ section.settings.subtitle }}
    </p>

    <!-- PRICE CHIP -->

    <div class="final-price-chip reveal">

      <span class="price-now">
        {{ section.settings.new_price }}
      </span>

      <span class="price-was">
        {{ section.settings.old_price }}
      </span>

      <span class="price-tag">
        {{ section.settings.price_tag }}
      </span>

    </div>

    <!-- BUTTON -->

    <form
      class="luxury-cta-form reveal"
      data-product-form
    >

      <input
        type="hidden"
        name="id"
        value="{{ all_products[section.settings.product].selected_or_first_available_variant.id }}"
      >

      <button
        type="submit"
        class="final-cta-button"
      >

        {{ section.settings.button_text }}

        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
        >
          <path
            d="M12 2L14.9 9.1L22 12L14.9 14.9L12 22L9.1 14.9L2 12L9.1 9.1L12 2Z"
            fill="#D9BA82"
          />
        </svg>

      </button>

    </form>

    <!-- TRUST -->

    <div class="final-cta-trust reveal">
      {{ section.settings.trust_line }}
    </div>

  </div>

</section>

<style>

#final-cta-{{ section.id }}{
  position: relative;

  width: 100vw;
  max-width: 100vw;

  left: 50%;
  right: 50%;

  margin-left: -50vw;
  margin-right: -50vw;

  overflow: hidden;

  text-align: center;

  padding: 140px 56px;

  background:
    radial-gradient(
      ellipse at 50% 100%,
      rgba(91,74,122,0.4) 0%,
      transparent 60%
    ),
    linear-gradient(
      180deg,
      #E4D9EE 0%,
      #C9B8DC 100%
    );
}

#final-cta-{{ section.id }} *{
  box-sizing: border-box;
}

.final-cta-table{
  position: absolute;

  bottom: -20%;
  left: 50%;

  transform: translateX(-50%);

  width: 140%;
  height: 50%;

  background:
    radial-gradient(
      ellipse at 50% 0%,
      rgba(184,148,90,0.3) 0%,
      transparent 70%
    );

  pointer-events: none;
}

.final-cta-inner{
  position: relative;
  z-index: 2;

  width: 100%;
  max-width: 760px;

  margin: 0 auto;
}

.final-cta-eyebrow{
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;

  margin-bottom: 32px;
}

.final-cta-eyebrow::before,
.final-cta-eyebrow::after{
  content: "";

  width: 36px;
  height: 1px;

  background: #B8945A;

  opacity: 0.6;
}

.final-cta-eyebrow span{
  font-family: "Inter", sans-serif;
  font-size: 11px;
  font-weight: 500;

  letter-spacing: 0.32em;
  text-transform: uppercase;

  color: #8C6F3F;
}

.final-cta-title{
  margin: 0 0 20px;

  font-family: "Italiana", serif;
  font-size: clamp(56px, 8vw, 120px);
  line-height: 0.95;
  font-weight: 400;

  color: #2A2438;
}

.final-cta-title em{
  display: block;

  margin-top: 8px;

  font-family: "Pinyon Script", cursive;
  font-style: normal;
  font-size: 1.1em;

  color: #8C6F3F;

  text-transform: none !important;
}

.final-cta-subline{
  max-width: 44ch;

  margin: 0 auto 44px;

  font-family: "Cormorant Garamond", serif;
  font-style: italic;
  font-size: 22px;
  line-height: 1.5;

  color: rgba(42,36,56,0.75);
}

.final-price-chip{
  position: relative;

  display: inline-flex;
  align-items: center;
  justify-content: center;

  gap: 12px;

  overflow: hidden;

  padding: 22px 44px;

  border-radius: 999px;

  background: rgba(248,241,231,0.78);

  border: 1px solid rgba(184,148,90,0.28);

  backdrop-filter: blur(10px);

  box-shadow:
    0 12px 32px -16px rgba(42,36,56,0.18);

  min-height: 64px;

  margin-bottom: 32px;
}

.price-now{
  font-family: "Inter", sans-serif;

  font-size: 28px;
  font-weight: 700;

  line-height: 1;

  color: #8C6F3F;
}

.price-was{
  font-family: "Inter", sans-serif;

  font-size: 16px;
  font-weight: 500;

  line-height: 1;

  opacity: 0.5;

  text-decoration: line-through;

  color: #2A2438;
}

.price-tag{
  font-family: "Inter", sans-serif;

  font-size: 10px;
  font-weight: 600;

  letter-spacing: 0.14em;
  text-transform: uppercase;

  color: #B07A82;
}

.final-cta-button{
  position: relative;

  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12px;

  overflow: hidden;

  padding: 22px 44px;

  border-radius: 999px;

  background: #2A2438;

  border: none;

  cursor: pointer;

  font-family: "Inter", sans-serif;
  font-size: 13px;
  font-weight: 500;

  letter-spacing: 0.24em;
  text-transform: uppercase;
  text-decoration: none;

  color: #F8F1E7;

  box-shadow:
    0 12px 32px -16px rgba(42,36,56,0.4);

  transition:
    background 0.3s cubic-bezier(0.2,0.8,0.2,1),
    transform 0.3s cubic-bezier(0.2,0.8,0.2,1),
    box-shadow 0.3s cubic-bezier(0.2,0.8,0.2,1);
}

.final-cta-button::after{
  content: "";

  position: absolute;
  inset: 0;

  background:
    radial-gradient(
      circle at center,
      rgba(217,186,130,0.6) 0%,
      transparent 60%
    );

  opacity: 0;

  transition: opacity 0.3s ease;
}

.final-cta-button:hover{
  transform: translateY(-2px);

  background: #5B4A7A;

  box-shadow:
    0 16px 40px -12px rgba(91,74,122,0.5);
}

.final-cta-button:hover::after{
  opacity: 1;
}

.final-cta-button.is-loading{
  opacity: 0.7;

  transform: scale(0.98);

  pointer-events: none;
}

.final-cta-button.is-added{
  background: #8C6F3F;

  box-shadow:
    0 18px 44px -12px rgba(184,148,90,0.45);

  transform: translateY(-2px) scale(1.02);
}

.final-cta-button.is-added::before{
  content: 'Added To Cart';

  position: absolute;
  inset: 0;

  display: flex;
  align-items: center;
  justify-content: center;

  background: #8C6F3F;

  color: #F8F1E7;

  z-index: 5;

  letter-spacing: 0.18em;
}

.final-cta-button span,
.final-cta-button svg{
  position: relative;
  z-index: 2;
}

.final-cta-trust{
  margin-top: 32px;

  font-family: "JetBrains Mono", monospace;
  font-size: 10px;

  letter-spacing: 0.3em;
  text-transform: uppercase;

  opacity: 0.6;

  color: #2A2438;
}

.reveal{
  opacity: 0;

  transform: translateY(40px);

  animation:
    finalReveal 0.9s cubic-bezier(0.2,0.8,0.2,1) forwards;
}

.final-cta-title{
  animation-delay: 0.14s;
}

.final-cta-subline{
  animation-delay: 0.28s;
}

.final-price-chip{
  animation-delay: 0.42s;
}

.final-cta-button{
  animation-delay: 0.56s;
}

.final-cta-trust{
  animation-delay: 0.7s;
}

@keyframes finalReveal{
  to{
    opacity: 1;
    transform: translateY(0);
  }
}

@media screen and (max-width: 999px){

  #final-cta-{{ section.id }}{
    padding: 120px 32px;
  }

}

@media screen and (max-width: 700px){

  #final-cta-{{ section.id }}{
    padding: 90px 20px;
  }

  .final-price-chip{
    gap: 10px;

    padding: 18px 34px;
  }

  .final-cta-button{
    padding: 18px 34px;

    font-size: 12px;
  }

}

@media screen and (max-width: 480px){

  #final-cta-{{ section.id }}{
    padding: 90px 16px;
  }

  .final-price-chip{
    width: 100%;

    max-width: 340px;

    margin-left: auto;
    margin-right: auto;
  }

  .luxury-cta-form{
    width: 100%;
  }

  .final-cta-button{
    width: 100%;

    max-width: 340px;

    justify-content: center;
  }

}

</style>

<script>

document.addEventListener('DOMContentLoaded', () => {

  const form = document.querySelector('[data-product-form]');

  if (!form) return;

  form.addEventListener('submit', async (e) => {

    e.preventDefault();

    const formData = new FormData(form);

    formData.append(
      'sections',
      'cart-drawer,cart-icon-bubble'
    );

    formData.append(
      'sections_url',
      window.location.pathname
    );

    const button = form.querySelector('.final-cta-button');

    button.classList.add('is-loading');

    const response = await fetch('/cart/add.js', {
      method: 'POST',
      body: formData
    });

    const result = await response.json();

    button.classList.remove('is-loading');
    button.classList.add('is-added');

    setTimeout(() => {
      button.classList.remove('is-added');
    }, 1800);

    const cartDrawer = document.querySelector('cart-drawer');

    if (cartDrawer && cartDrawer.renderContents) {
      cartDrawer.renderContents(result);

      setTimeout(() => {
        cartDrawer.classList.add('animate', 'active');
      }, 180);
    }

  });

});

</script>

