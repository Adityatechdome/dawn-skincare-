<section class="luxury-pricing-cta">
  <div class="pricing-wrapper">
    <div class="pricing-image-side">
      {% if section.settings.product_image %}
        <img src="{{ section.settings.product_image | image_url: width: 500 }}" alt="{{ section.settings.title }}" class="pricing-image">
      {% else %}
        <div class="pricing-image-placeholder">Product Image</div>
      {% endif %}
    </div>

    <div class="pricing-content-side">
      <h2 style="color: {{ section.settings.title_color }}; font-size: {{ section.settings.title_font_size }}px;">{{ section.settings.title }}</h2>
      <div class="pricing-box" style="background: {{ section.settings.box_background_color }}; padding: {{ section.settings.box_padding }}px;">
        <p class="original-price" style="color: {{ section.settings.original_price_color }}; font-size: {{ section.settings.original_price_font_size }}px;"><s>{{ section.settings.original_price }}</s></p>
        <p class="sale-price" style="color: {{ section.settings.sale_price_color }}; font-size: {{ section.settings.sale_price_font_size }}px;">{{ section.settings.sale_price }}</p>
        <p class="discount-badge" style="background: {{ section.settings.badge_background_color }}; color: {{ section.settings.badge_text_color }}; font-size: {{ section.settings.badge_font_size }}px;">{{ section.settings.discount_text }}</p>
      </div>
      <a href="{{ section.settings.cta_link }}" class="pricing-cta" style="background: {{ section.settings.button_background_color }}; color: {{ section.settings.button_text_color }}; border-color: {{ section.settings.button_background_color }}; font-size: {{ section.settings.button_font_size }}px; padding: {{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;">{{ section.settings.cta_text }}</a>
    </div>
  </div>
</section>

<style>
  .luxury-pricing-cta {
    padding: 80px 56px;
    background: linear-gradient(135deg, #E4D9EE 0%, #C9B8DC 100%);
  }

  .pricing-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    max-width: 1400px;
    margin: 0 auto;
    align-items: center;
  }

  .pricing-image-side {
    aspect-ratio: 1;
    position: relative;
    overflow: hidden;
    border: 12px solid #B8945A;
    box-shadow:
      inset 0 0 30px rgba(184, 148, 90, 0.1),
      0 0 30px rgba(184, 148, 90, 0.2);
    background: white;
  }

  .pricing-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pricing-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #FBF6EE, #EFE4D2);
    color: #8E7AAB;
    font-family: "Inter", sans-serif;
    font-size: 18px;
  }

  .pricing-content-side {
    text-align: left;
  }

  .pricing-content-side h2 {
    font-family: "Italiana", serif;
    font-size: 48px;
    color: #2A2438;
    margin: 0 0 40px 0;
    letter-spacing: 0.08em;
  }

  .pricing-box {
    background: white;
    padding: 40px;
    margin-bottom: 40px;
    border: 1px solid rgba(184, 148, 90, 0.2);
  }

  .original-price {
    font-family: "Cormorant Garamond", serif;
    font-size: 24px;
    color: #8E7AAB;
    margin: 0 0 10px 0;
  }

  .sale-price {
    font-family: "Italiana", serif;
    font-size: 56px;
    color: #B8945A;
    margin: 0;
  }

  .discount-badge {
    font-family: "Inter", sans-serif;
    font-size: 12px;
    color: #E8C9CC;
    background: #B07A82;
    display: inline-block;
    padding: 8px 16px;
    margin-top: 20px;
    letter-spacing: 0.1em;
  }

  .pricing-cta {
    display: inline-block;
    padding: 16px 48px;
    background: #B8945A;
    color: white;
    text-decoration: none;
    font-size: 14px;
    letter-spacing: 0.15em;
    border: 2px solid #B8945A;
    transition: all 0.3s ease;
  }

  .pricing-cta:hover {
    background: transparent;
    color: #B8945A;
  }

  @media (max-width: 1000px) {
    .pricing-wrapper {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .pricing-content-side h2 {
      font-size: 36px;
    }
  }

  @media (max-width: 768px) {
    .luxury-pricing-cta {
      padding: 40px 20px;
    }

    .pricing-wrapper {
      gap: 30px;
    }

    .pricing-content-side h2 {
      font-size: 32px;
    }

    .sale-price {
      font-size: 40px;
    }
  }
</style>

{% schema %}
{
  "name": "Luxury Pricing CTA",
  "settings": [
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Image"
    },
    {
      "type": "heading",
      "content": "Title Settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Limited Time Offer"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 24,
      "max": 72,
      "step": 1,
      "unit": "px",
      "label": "Title Font Size",
      "default": 48
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#2A2438"
    },
    {
      "type": "heading",
      "content": "Price Box Settings"
    },
    {
      "type": "color",
      "id": "box_background_color",
      "label": "Box Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "box_padding",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Box Padding",
      "default": 40
    },
    {
      "type": "heading",
      "content": "Original Price Settings"
    },
    {
      "type": "text",
      "id": "original_price",
      "label": "Original Price",
      "default": "$222"
    },
    {
      "type": "range",
      "id": "original_price_font_size",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Original Price Font Size",
      "default": 24
    },
    {
      "type": "color",
      "id": "original_price_color",
      "label": "Original Price Color",
      "default": "#8E7AAB"
    },
    {
      "type": "heading",
      "content": "Sale Price Settings"
    },
    {
      "type": "text",
      "id": "sale_price",
      "label": "Sale Price",
      "default": "$111"
    },
    {
      "type": "range",
      "id": "sale_price_font_size",
      "min": 24,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Sale Price Font Size",
      "default": 56
    },
    {
      "type": "color",
      "id": "sale_price_color",
      "label": "Sale Price Color",
      "default": "#B8945A"
    },
    {
      "type": "heading",
      "content": "Discount Badge Settings"
    },
    {
      "type": "text",
      "id": "discount_text",
      "label": "Discount Text",
      "default": "50% OFF"
    },
    {
      "type": "color",
      "id": "badge_background_color",
      "label": "Badge Background Color",
      "default": "#B07A82"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge Text Color",
      "default": "#E8C9CC"
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Badge Font Size",
      "default": 12
    },
    {
      "type": "heading",
      "content": "Button Settings"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Claim Your Offer"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button Background Color",
      "default": "#B8945A"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Button Font Size",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_x",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Button Horizontal Padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "button_padding_y",
      "min": 8,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Button Vertical Padding",
      "default": 16
    }
  ]
}
{% endschema %}
