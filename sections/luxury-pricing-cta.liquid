{% schema %}
{
  "name": "Luxury Pricing CTA",
  "settings": [
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Image"
    },
    {
      "type": "header",
      "content": "Title Settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Limited Time Offer"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 24,
      "max": 72,
      "step": 1,
      "unit": "px",
      "label": "Title Font Size",
      "default": 48
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#2A2438"
    },
    {
      "type": "header",
      "content": "Price Box Settings"
    },
    {
      "type": "color",
      "id": "box_background_color",
      "label": "Box Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "box_padding",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Box Padding",
      "default": 40
    },
    {
      "type": "header",
      "content": "Original Price Settings"
    },
    {
      "type": "text",
      "id": "original_price",
      "label": "Original Price",
      "default": "$222"
    },
    {
      "type": "range",
      "id": "original_price_font_size",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Original Price Font Size",
      "default": 24
    },
    {
      "type": "color",
      "id": "original_price_color",
      "label": "Original Price Color",
      "default": "#8E7AAB"
    },
    {
      "type": "header",
      "content": "Sale Price Settings"
    },
    {
      "type": "text",
      "id": "sale_price",
      "label": "Sale Price",
      "default": "$111"
    },
    {
      "type": "range",
      "id": "sale_price_font_size",
      "min": 24,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Sale Price Font Size",
      "default": 56
    },
    {
      "type": "color",
      "id": "sale_price_color",
      "label": "Sale Price Color",
      "default": "#B8945A"
    },
    {
      "type": "header",
      "content": "Discount Badge Settings"
    },
    {
      "type": "text",
      "id": "discount_text",
      "label": "Discount Text",
      "default": "50% OFF"
    },
    {
      "type": "color",
      "id": "badge_background_color",
      "label": "Badge Background Color",
      "default": "#B07A82"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge Text Color",
      "default": "#E8C9CC"
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Badge Font Size",
      "default": 12
    },
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Claim Your Offer"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button Background Color",
      "default": "#B8945A"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Button Font Size",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_x",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Button Horizontal Padding",
      "default": 50   // ✅ FIXED
    },
    {
      "type": "range",
      "id": "button_padding_y",
      "min": 8,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Button Vertical Padding",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Luxury Pricing CTA"
    }
  ]
}
{% endschema %}