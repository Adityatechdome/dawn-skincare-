<link href="https://fonts.googleapis.com/css2?family=Italiana&family=Cormorant+Garamond:ital,wght@0,400;1,400&family=Pinyon+Script&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">

<header class="luxury-nav">
  <div class="luxury-nav-inner">

    <!-- LEFT -->
    <div class="luxury-nav-left">

      {% if section.settings.logo_image != blank %}
        <img
          src="{{ section.settings.logo_image | image_url }}"
          alt="{{ shop.name }}"
          class="luxury-logo-image"
          width="120"
          height="120"
        >
      {% endif %}

      <div class="luxury-logo-text">
        {{ section.settings.logo_text }}
      </div>

    </div>

    <!-- DESKTOP MENU -->
    <nav class="luxury-menu desktop-menu">
      {% for link in linklists[section.settings.menu].links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </nav>

    <!-- RIGHT -->
    <div class="luxury-icons">

      <!-- SEARCH -->
      <a href="/search" class="luxury-icon">
        {% if section.settings.search_icon != blank %}
          <img
            src="{{ section.settings.search_icon | image_url }}"
            alt="Search"
            class="luxury-custom-icon"
            width="24"
            height="24"
          >
        {% else %}
          🔍
        {% endif %}
      </a>

      <!-- ACCOUNT -->
      <a href="/account" class="luxury-icon">
        {% if section.settings.account_icon != blank %}
          <img
            src="{{ section.settings.account_icon | image_url }}"
            alt="Account"
            class="luxury-custom-icon"
            width="24"
            height="24"
          >
        {% else %}
          👤
        {% endif %}
      </a>

      <!-- CART -->
      <a href="/cart" class="luxury-icon luxury-cart-icon">

        {% if section.settings.cart_icon != blank %}
          <img
            src="{{ section.settings.cart_icon | image_url }}"
            alt="Cart"
            class="luxury-custom-icon"
            width="24"
            height="24"
          >
        {% else %}
          🛒
        {% endif %}

        <span class="luxury-cart-count">
          {{ cart.item_count }}
        </span>

      </a>

      <!-- MOBILE MENU -->
      <button class="mobile-menu-toggle" onclick="toggleDrawer()">
        ☰
      </button>

    </div>

  </div>

  <!-- MOBILE DRAWER -->
  <div class="mobile-drawer" id="mobileDrawer">

    <button class="drawer-close" onclick="toggleDrawer()">
      ✕
    </button>

    {% for link in linklists[section.settings.menu].links %}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {% endfor %}

    <div class="mobile-drawer-icons">

      <a href="/search">Search</a>
      <a href="/account">Account</a>
      <a href="/cart">Cart</a>

    </div>

  </div>
</header>

<style>
.luxury-nav {
  width: 100%;
  background: {{ section.settings.background_color }};
  border-bottom: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};
  position: {{ section.settings.position }};
  top: 0;
  left: 0;
  z-index: 999;
}

.luxury-nav-inner {
  max-width: {{ section.settings.max_width }}px;
  margin: 0 auto;

  padding:
    {{ section.settings.padding_vertical }}px
    {{ section.settings.padding_horizontal }}px;

  display: flex;
  align-items: center;
  justify-content: space-between;
}

.luxury-nav-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.luxury-logo-image {
  width: 42px;
  height: auto;
  object-fit: contain;
}

.luxury-logo-text {
  font-size: {{ section.settings.logo_size }}px;
  color: {{ section.settings.logo_color }};
  font-weight: 600;
  line-height: 1;
}

.luxury-menu {
  display: flex;
  align-items: center;
  gap: {{ section.settings.menu_gap }}px;
}

.luxury-menu a {
  text-decoration: none;
  color: {{ section.settings.text_color }};
  font-size: 14px;
  transition: 0.3s ease;
}

.luxury-menu a:hover {
  opacity: 0.7;
}

.luxury-icons {
  display: flex;
  align-items: center;
  gap: 16px;
}

.luxury-icon {
  text-decoration: none;
  color: {{ section.settings.icon_color }};
  font-size: 18px;
  transition: 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.luxury-icon:hover {
  opacity: 0.7;
}

.luxury-cart-icon{
  position: relative;
}

.luxury-cart-count{
  position: absolute;

  top: -8px;
  right: -10px;

  min-width: 18px;
  height: 18px;

  padding: 0 5px;

  border-radius: 999px;

  background: #D9BA82;
  color: #2A2438;

  display: flex;
  align-items: center;
  justify-content: center;

  font-family: "Inter", sans-serif;
  font-size: 10px;
  font-weight: 700;

  line-height: 1;

  transition:
    transform 0.3s ease,
    opacity 0.3s ease;
}

.luxury-cart-count.bump{
  animation: luxuryCartPulse 0.45s ease;
}

@keyframes luxuryCartPulse {

  0%{
    transform: scale(1);
  }

  40%{
    transform: scale(1.45);
  }

  70%{
    transform: scale(0.92);
  }

  100%{
    transform: scale(1);
  }

}

.luxury-custom-icon {
  width: 20px;
  height: 20px;
  object-fit: contain;
  display: block;
}

.mobile-menu-toggle {
  display: none;
  border: none;
  background: transparent;
  font-size: 24px;
  cursor: pointer;
  color: {{ section.settings.icon_color }};
}

.mobile-drawer {
  position: fixed;
  top: 0;
  right: -100%;
  width: 300px;
  height: 100vh;
  background: {{ section.settings.background_color }};
  z-index: 99999;

  padding: 80px 30px;

  display: flex;
  flex-direction: column;
  gap: 24px;

  transition: 0.4s ease;
}

.mobile-drawer.active {
  right: 0;
}

.mobile-drawer a {
  text-decoration: none;
  color: {{ section.settings.text_color }};
  font-size: 16px;
}

.drawer-close {
  position: absolute;
  top: 20px;
  right: 20px;

  background: transparent;
  border: none;
  font-size: 28px;
  cursor: pointer;
  color: {{ section.settings.text_color }};
}

.mobile-drawer-icons {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-top: 30px;
  padding-top: 20px;
  border-top: 1px solid {{ section.settings.border_color }};
}

@media screen and (max-width: 768px) {

  .desktop-menu {
    display: none;
  }

  .mobile-menu-toggle {
    display: block;
  }

  .luxury-nav-inner {

    padding:
      {{ section.settings.padding_vertical_mobile }}px
      {{ section.settings.padding_horizontal_mobile }}px;

  }

  .luxury-logo-image {
    width: 34px;
  }

  .luxury-logo-text {
    font-size: 18px;
  }

  .luxury-icons {
    gap: 12px;
  }

  .luxury-icon {
    font-size: 16px;
  }
}
</style>

<script>
function toggleDrawer() {
  document.getElementById('mobileDrawer').classList.toggle('active');
}

document.addEventListener('DOMContentLoaded', function(){

  const cartCount =
    document.querySelector('.luxury-cart-count');

  async function refreshCartCount(){

    try{

      const response =
        await fetch('/cart.js');

      const cart =
        await response.json();

      if(cartCount){

        const previousCount =
          parseInt(cartCount.innerText) || 0;

        const newCount =
          cart.item_count;

        cartCount.innerHTML = newCount;

        if(newCount !== previousCount){

          cartCount.classList.remove('bump');

          void cartCount.offsetWidth;

          cartCount.classList.add('bump');

          setTimeout(() => {

            cartCount.classList.remove('bump');

          }, 450);

        }

      }

    }catch(error){

      console.error(error);

    }

  }

  document.addEventListener(
    'cart:updated',
    refreshCartCount
  );

  document.body.addEventListener(
    'submit',
    async function(e){

      const form =
        e.target;

      if(form.matches('form[action*="/cart/add"]')){

        setTimeout(() => {

          refreshCartCount();

        }, 300);

      }

    },
    true
  );

  document.body.addEventListener(
    'click',
    function(){

      setTimeout(() => {

        refreshCartCount();

      }, 500);

    }
  );

  refreshCartCount();

});
</script>

{% schema %}
{
  "name": "Luxury Navigation",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "DAWN"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main Menu"
    },
    {
      "type": "header",
      "content": "Custom Icons"
    },
    {
      "type": "image_picker",
      "id": "search_icon",
      "label": "Search Icon"
    },
    {
      "type": "image_picker",
      "id": "account_icon",
      "label": "Account Icon"
    },
    {
      "type": "image_picker",
      "id": "cart_icon",
      "label": "Cart Icon"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Position",
      "options": [
        {
          "value": "relative",
          "label": "Relative"
        },
        {
          "value": "fixed",
          "label": "Fixed"
        },
        {
          "value": "sticky",
          "label": "Sticky"
        }
      ],
      "default": "fixed"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 2000,
      "step": 50,
      "unit": "px",
      "label": "Max Width",
      "default": 1400
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Padding Vertical",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Horizontal",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_vertical_mobile",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Padding Vertical Mobile",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Padding Horizontal Mobile",
      "default": 20
    },
    {
      "type": "range",
      "id": "logo_size",
      "min": 14,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Logo Text Size",
      "default": 22
    },
    {
      "type": "color",
      "id": "logo_color",
      "label": "Logo Color",
      "default": "#2A2438"
    },
    {
      "type": "range",
      "id": "menu_gap",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Menu Gap",
      "default": 32
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F8F1E7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#2A2438"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#B8945A"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "label": "Border Width",
      "default": 1
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#2A2438"
    }
  ],
  "presets": [
    {
      "name": "Luxury Navigation"
    }
  ]
}
{% endschema %}