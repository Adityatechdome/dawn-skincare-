              </g>
              <defs>
                <clipPath id="clip0_136_2139">
                  <rect
                    width="24"
                    height="24"
                    fill="white" />
                </clipPath>
              </defs>
            </svg>
          </a>
        {% endif %}
        {% if section.settings.facebook_url != blank %}
          <a
            href="{{ section.settings.facebook_url }}"
            target="_blank"
            rel="noopener"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path d="M17.2137 13.3278L17.8356 9.23262H13.9452V6.57631C13.9452 5.45568 14.4877 4.36272 16.2301 4.36272H18V0.876308C18 0.876308 16.3945 0.599609 14.8603 0.599609C11.6548 0.599609 9.56164 2.56141 9.56164 6.11145V9.23262H6V13.3278H9.56164V23.2281C10.2767 23.3415 11.0082 23.3996 11.7534 23.3996C12.4986 23.3996 13.2301 23.3415 13.9452 23.2281V13.3278H17.2137Z" fill="white" />
            </svg>
          </a>
        {% endif %}
      </div>
      <div class="footer-business-info">
        <p>
          25 Griffin Place<br>
          Doonside NSW - 2767
        </p>
        {% comment %} <p>
          <a href="tel:+61450772126">+61 450 772 126</a>
        </p>
        <p>
          <a href="mailto:dawnskincareaus@gmail.com">dawnskincareaus@gmail.com</a>
        </p> {% endcomment %}
      </div>
    </div>

    <!-- Dynamic menu columns -->
    <div class="footer-menu-wrap">
      <div class="footer-column">
        <h3>Products</h3>
        <ul>
          {% for link in linklists[section.settings.menu_products].links %}
            <li>
              <a href="{{ link.url }}">{{ link.title }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>

      <div class="footer-column">
        <h3>Guides</h3>
        <ul>
          {% for link in linklists[section.settings.menu_guides].links %}
            <li>
              <a href="{{ link.url }}">{{ link.title }}</a>
            </li>
          {% endfor %}
          {% comment %}
            <li>
              <a href="/#faq">QNA</a>
            </li>
          {% endcomment %}
        </ul>
      </div>

      <div class="footer-column">
        <h3>Contact</h3>
        <ul>
          {% for link in linklists[section.settings.menu_contact].links %}
            <li>
              <a href="{{ link.url }}">{{ link.title }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>

  <!-- Footer bottom -->
  <div class="footer-bottom">
    <p class="footer-copy">{{ section.settings.copyright_text }}</p>
    <ul class="footer-links">
      {% for link in linklists[section.settings.menu_bottom].links %}
        <li>
          <a href="{{ link.url }}">{{ link.title }}</a>
        </li>
      {% endfor %}
    </ul>
  </div>
</footer>

<style>
    .footer {
      background-color: #333333;
      padding: 68px 40px 48px;
    }

    .footer-top {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
    }

    .footer-menu-wrap {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      max-width: 950px;
      width: 100%;
    }

    .flex-column {
      flex: 1;
    }

    .footer-brand {
      display: flex;
      flex-direction: column;
      align-items:center;
      gap: 24px;
    }

    .footer-logo {
      width: 180px;
      height: auto;
      aspect-ratio: 1 / 1;
    }

    .footer-logo-text {
      font-family: Valky;
      font-weight: 400;
      font-size: 40px;
      line-height: 100%;
      letter-spacing: 0;
      color: #eeeae1;
      margin: 0;
    }

    .footer-follow {
      font-size: 13px;
      margin: 0;
      color: #dcdcdc;
      letter-spacing: 1px;
      text-align:center;
    }

    .footer-socials {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
    }

    .footer-socials a {
      color: #e5e5e5;
      font-size: 20px;
      text-decoration: none;
      transition: opacity 0.3s ease;
    }

    .footer-socials a:hover {
      opacity: 0.7;
    }

    .footer-business-info {
    margin-top: 20px;
    text-align:center;
  }

  .footer-business-info p {
    font-family: Poppins;
    font-weight: 400;
    font-size: 14px;
    line-height: 23.8px;
    color: #cdcbc0;
    margin: 0 0 10px;
  }

  .footer-business-info a {
    color: #cdcbc0;
    text-decoration: none;
  }

  .footer-business-info a:hover {
    opacity: 0.7;
  }

    .footer-column h3 {
      font-family: Poppins;
      font-weight: 700;
      font-size: 16px;
      line-height: 23.8px;
      letter-spacing: -2%;
      color: #ffffff;
      margin: 0 0 24px;
    }

    .footer-column ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .footer-column li {
      margin-bottom: 14px;
    }

    .footer-column a {
      color: #cdcbc0;
      text-decoration: none;
      font-family: Poppins;
      font-weight: 400;
      font-size: 14px;
      line-height: 23.8px;
      transition: opacity 0.3s ease;
    }

    .footer-column a:hover {
      opacity: 0.7;
    }

    .footer-bottom {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      margin-top: 150px;
    }

    .footer-bottom p {
      font-family: Poppins;
      font-weight: 400;
      font-style: Regular;
      font-size: 11px;
      line-height: 100%;
      letter-spacing: 2%;
      margin: 0;
      color: #cdcbc0;
    }

    .footer-links {
      display: flex;
      flex-wrap: wrap;
      gap: 18px;
      list-style: none;
      padding: 0;
      margin: 0;
      max-width: 950px;
      width: 100%;
    }

    .footer-links a {
      font-family: Poppins;
      font-weight: 400;
      font-size: 11px;
      line-height: 100%;
      letter-spacing: 2%;
      color: #CDCBC0;
      text-decoration: none;
    }

    .footer-links a:hover {
      opacity: 0.7;
    }

    @media (max-width: 1280px) and (min-width: 901px) {
      .footer-menu-wrap,
      .footer-links {
        max-width: 600px;
      }
    }

    @media (max-width: 901px) and (min-width: 500px) {
      .footer-links {
        justify-content: center;
      }
    }

    @media (max-width: 900px) {
      .footer {
        padding: 68px 40px 48px;
      }

      .footer-logo {
        width: 100%;
      }

      .footer-brand {
        width: 100%;
      }
      .footer-socials {
        justify-content: center;
      }

      .footer-top {
        gap: 40px;
      }

      .footer-menu-wrap {
        align-items: start;
        justify-content: space-between;
        row-gap: 40px;
      }

      .footer-column {
        flex: 0 0 35%;
      }

      .footer-bottom {
        margin-top: 100px;
        flex-direction: column-reverse;
        justify-content: center;
      }

      .footer-links {
        max-width: 350px;
        margin: 0 auto 50px;
      }
    }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const footerLinks = document.querySelectorAll('.footer a');
    footerLinks.forEach((link) => {
      if (link.textContent.trim().toUpperCase() === 'QNA') {
        link.href = '/#faq';
      }
    });
  });
</script>
