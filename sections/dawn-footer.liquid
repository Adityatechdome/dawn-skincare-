{% schema %}
{
  "name": "Custom Footer",
  "tag": "footer",
  "class": "custom-footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer Logo"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "DAWN. 2019 KINS All rights reserved."
    },
    {
      "type": "link_list",
      "id": "menu_products",
      "label": "Products Menu"
    },
    {
      "type": "link_list",
      "id": "menu_guides",
      "label": "Guides Menu"
    },
    {
      "type": "link_list",
      "id": "menu_service",
      "label": "Service Menu"
    },
    {
      "type": "link_list",
      "id": "menu_contact",
      "label": "Contact Menu"
    },
    {
      "type": "link_list",
      "id": "menu_bottom",
      "label": "Bottom Links Menu"
    },
    {
      "type": "header",
      "content": "Social Media Links"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "Twitter URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    }
  ],
  "presets": [
    {
      "name": "Dynamic Footer",
      "category": "Footer"
    }
  ]
}
{% endschema %}

<footer class="footer">
  <div class="footer-top">
    <!-- Left brand column -->
    <div class="footer-brand">
      {% if section.settings.footer_logo %}
        {{
          section.settings.footer_logo
          | image_url: width: 1200
          | image_tag:
            alt: 'Logo',
            class: 'footer-logo',
            loading: 'lazy',
            decoding: 'async',
            width: 180,
            height: 180
        }}
      {% else %}
        <h2 class="footer-logo-text">DAWN</h2>
      {% endif %}

      {% comment %} <p class="footer-follow">FOLLOW US</p> {% endcomment %}
      <div class="footer-socials">
        {% if section.settings.twitter_url != blank %}
          <a
            href="{{ section.settings.twitter_url }}"
            target="_blank"
            rel="noopener"
          >
