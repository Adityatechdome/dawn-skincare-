          "type": "faq_item",
          "settings": {
            "question": "Are your products suitable for all skin types?",
            "answer": "Yes. Each formula is thoughtfully crafted with gentle, dermatologist-tested ingredients to ensure compatibility with all skin types — including sensitive, dry, combination, and mature skin."
          }
        },
        "faq_item_N9Q4j7": {
          "type": "faq_item",
          "settings": {
            "question": "Are your products cruelty-free?",
            "answer": "Absolutely. We are committed to ethical beauty and do not test on animals at any stage of product development."
          }
        },
        "faq_item_af3Lht": {
          "type": "faq_item",
          "settings": {
            "question": "When will I start seeing visible results?",
            "answer": "Most customers begin to notice improved hydration, radiance, and smoother texture within 7–14 days of consistent use, while deeper benefits such as reduced fine lines and improved firmness become more noticeable over 4–6 weeks."
          }
        },
        "faq_item_Vdtzht": {
          "type": "faq_item",
          "settings": {
            "question": "Can I layer your products with other skincare brands?",
            "answer": "Yes. Our formulations are designed to integrate seamlessly into any routine. For optimal results, layer lighter serums first, followed by creams or oils, and always finish with sunscreen during daytime use."
          }
        },
        "faq_item_tDGdmc": {
          "type": "faq_item",
          "settings": {
            "question": "Are your products safe for sensitive skin?",
            "answer": "Yes. Our products are formulated with soothing botanical extracts, non-irritating actives, and balanced concentrations to minimize sensitivity. However, we always recommend a patch test when introducing a new product."
          }
        },
        "faq_item_gk6kWc": {
          "type": "faq_item",
          "settings": {
            "question": "What is the best order to follow in my skincare routine?",
            "answer": "A refined and effective routine follows this sequence:\nCleanser → Toner → Serum → Treatment (Capsule creams/oils) → Moisturizer → Sunscreen (AM only)\nThis ensures your skin receives maximum nourishment and protection."
          }
        }
      },
