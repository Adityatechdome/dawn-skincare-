<div class="product-card">
  <div class="product-image">
    <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}" loading="lazy">
  </div>
  <a href="{{ product.url }}" class="product-button">Shop {{ product.metafields.custom.tags }}</a>
</div>

<style>
  .product-card {
    max-width: 422px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 40px;
    justify-content: center;
  }

  .product-image {
    width: 100%;
    height: auto;
    max-height: 288px;
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-button {
    display: inline-block;
    padding: 19px 23px;
    background-color: #333333;
    border: 1px solid #333333;
    color: #fff;
    cursor: pointer;
    transition: background-color 0.3s ease;
    font-family: Poppins;
    font-weight: 400;
    font-size: 14px;
    line-height: 23.8px;
    letter-spacing: -1%;
    text-align: center;
  }

  @media (max-width: 600px) {
    .product-card {
      max-width: 297px;
      gap: 26px;
    }

    .product-image img {
      max-height: 233px;
    }

    .product-button {
      font-size: 18px;
    }
  }
</style>
