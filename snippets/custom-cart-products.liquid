{%- comment -%}
  Custom Cart Products - Displays cart items with custom styling
{%- endcomment -%}

<script
  src="{{ 'component-cart-items.js' | asset_url }}"
  type="module"
></script>

<div class="custom-cart-products">
  {%- if cart.empty? -%}
    <div class="custom-cart-products__empty">
      <p>Your cart is currently empty</p>
    </div>
  {%- else -%}
    <span
      class="visually-hidden"
      ref="cartItemCount"
      aria-hidden="true"
    >
      {{- cart.item_count -}}
    </span>
    
    <form
      action="{{ routes.cart_url }}"
      class="custom-cart-form"
      id="cart-form"
      method="post"
    >
      <div class="custom-cart-products__list">
        {% for item in cart.items %}
          <div
            class="custom-cart-item"
            ref="cartItemRows[]"
            data-key="{{ item.key }}"
            data-line="{{ item.index | plus: 1 }}"
          >
            {%- comment -%} Product Image {%- endcomment -%}
            <div class="custom-cart-item__image">
              {% if item.image %}
                <a href="{{ item.url }}">
                  <img
                    src="{{ item.image | image_url: width: 200 }}"
                    alt="{{ item.title | escape }}"
                    loading="lazy"
                    width="88"
                    height="88"
                  >
                </a>
              {% endif %}
            </div>

            {%- comment -%} Product Details {%- endcomment -%}
            <div class="custom-cart-item__details">
              {%- comment -%} Title and Price Row {%- endcomment -%}
              <div class="custom-cart-item__header">
                <div class="custom-cart-item__info">
                  <h3 class="custom-cart-item__title">
                    <a href="{{ item.url }}">{{ item.product.title }}</a>
                  </h3>
                </div>

                {%- comment -%} Price Section - Right side by title {%- endcomment -%}
                <div class="custom-cart-item__price-section">
                  {%- if item.original_price != item.final_price or item.variant.compare_at_price > item.original_price -%}
                    {%- liquid
                      assign compare_price = item.variant.compare_at_price
                      if item.variant.compare_at_price <= item.original_price
                        assign compare_price = item.original_price
                      endif
                      assign compare_line_price = compare_price | times: item.quantity
                    -%}
                    <s class="custom-cart-item__price-compare">{{ compare_line_price | money }}</s>
                    <text-component value="{{ item.final_line_price | money | strip_html }}" class="custom-cart-item__price-sale">
                      {{ item.final_line_price | money }}
                    </text-component>
                  {%- else -%}
                    <text-component value="{{ item.final_line_price | money | strip_html }}" class="custom-cart-item__price-regular">
                      {{ item.final_line_price | money }}
                    </text-component>
                  {%- endif -%}
                </div>
              </div>

              {%- comment -%} Variant and Savings Badge Row {%- endcomment -%}
              <div class="custom-cart-item__variant-savings-row">
                {%- comment -%} Variant Options (e.g., size) {%- endcomment -%}
                {%- if item.product.has_only_default_variant == false -%}
                  <div class="custom-cart-item__variants">
                    {%- for option in item.options_with_values -%}
                      <div class="custom-cart-item__variant">
                        <span class="custom-cart-item__variant-label">{{ option.name | downcase }}:</span>
                        <select
                          class="custom-cart-item__variant-select"
                          data-line="{{ item.index | plus: 1 }}"
                          data-option-index="{{ forloop.index0 }}"
                        >
                          {%- for value in item.product.options_by_name[option.name].values -%}
                            <option
                              value="{{ value }}"
                              {% if value == option.value %}selected{% endif %}
                            >
                              {{ value }}
                            </option>
                          {%- endfor -%}
                        </select>
                      </div>
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                {%- comment -%} Savings Badge - Right side to size {%- endcomment -%}
                {%- if item.original_price != item.final_price or item.variant.compare_at_price > item.original_price -%}
                  {%- liquid
                    assign compare_price = item.variant.compare_at_price
                    if item.variant.compare_at_price <= item.original_price
                      assign compare_price = item.original_price
                    endif
                    assign compare_line_price = compare_price | times: item.quantity
                    assign savings = compare_line_price | minus: item.final_line_price
                  -%}
                  
                  {%- if savings > 0 -%}
                    <div class="custom-cart-item__savings-badge">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M21 8.94a1.31 1.31 0 0 0-.06-.27v-.09a1.07 1.07 0 0 0-.19-.28l-6-6a1.07 1.07 0 0 0-.28-.19.32.32 0 0 0-.09 0 .88.88 0 0 0-.33-.11H8a3 3 0 0 0-3 3v14a3 3 0 0 0 3 3h8a3 3 0 0 0 3-3V8.94zm-6-3.53L17.59 8H16a1 1 0 0 1-1-1zM16 20H8a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1h5v3a3 3 0 0 0 3 3h1v9a1 1 0 0 1-1 1z" fill="currentColor"/>
                        <path d="M13 13h-2a1 1 0 0 0 0 2h2a1 1 0 0 0 0-2zm0-4h-2a1 1 0 0 0 0 2h2a1 1 0 0 0 0-2z" fill="currentColor"/>
                      </svg>
                      <text-component value="{{ savings | money | strip_html }}">
                        You save {{ savings | money }}
                      </text-component>
                    </div>
                  {%- endif -%}
                {%- endif -%}
              </div>

              {%- comment -%} Quantity and Remove Button Row {%- endcomment -%}
              <div class="custom-cart-item__footer">
                <div class="custom-cart-item__quantity">
                  {% render 'quantity-selector',
                    product: item.product,
                    in_cart_quantity: item.quantity,
                    line_index: item.index,
                    min: 0,
                    class: 'custom-quantity-selector'
                  %}
                </div>

                {%- comment -%} Delete Button - Right side to quantity {%- endcomment -%}
                <button
                  class="custom-cart-item__remove"
                  type="button"
                  aria-label="Remove {{ item.title | escape }}"
                  on:click="/onLineItemRemove/{{ item.index | plus: 1 }}"
                >
                  {{- 'icon-delete.svg' | inline_asset_content -}}
                </button>
              </div>

              {%- comment -%} Error Message {%- endcomment -%}
              <div
                class="custom-cart-item__error hidden"
                ref="cartItemErrorContainer-{{ item.index | plus: 1 }}"
              >
                <span class="custom-cart-item__error-icon">
                  {{- 'icon-error.svg' | inline_asset_content -}}
                </span>
                <small
                  class="custom-cart-item__error-text"
                  ref="cartItemError-{{ item.index | plus: 1 }}"
                ></small>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </form>
  {%- endif -%}
</div>

{% stylesheet %}
  .custom-cart-products {
    width: 100%;
  }

  .custom-cart-products__list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .custom-cart-item {
    display: flex;
    gap: 16px;
    position: relative;
  }

  .custom-cart-item.removing {
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .custom-cart-item__image {
    flex-shrink: 0;
    width: 88px;
    height: 88px;
    border-radius: 8px;
    overflow: hidden;
    background: #f5f5f5;
  }

  .custom-cart-item__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .custom-cart-item__details {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .custom-cart-item__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }

  .custom-cart-item__info {
    flex: 1;
  }

  .custom-cart-item__title {
    font-size: 16px;
    font-weight: 500;
    margin: 0;
    line-height: 1.4;
  }

  .custom-cart-item__title a {
    color: #000;
    text-decoration: none;
  }

  .custom-cart-item__price-section {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }

  .custom-cart-item__price-compare {
    font-size: 14px;
    color: #999;
    text-decoration: line-through;
    font-weight: 400;
  }

  .custom-cart-item__price-sale {
    font-size: 18px;
    font-weight: 600;
    color: #000;
  }

  .custom-cart-item__price-regular {
    font-size: 18px;
    font-weight: 600;
    color: #000;
  }

  .custom-cart-item__variant-savings-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .custom-cart-item__variants {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .custom-cart-item__variant {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .custom-cart-item__variant-label {
    font-size: 14px;
    color: #666;
  }

  .custom-cart-item__variant-select {
    font-size: 14px;
    padding: 4px 24px 4px 8px;
    border: 1px solid #e5e5e5;
    border-radius: 4px;
    background: #fff;
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%23000' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 8px center;
  }

  .custom-cart-item__savings-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #d4f4dd;
    color: #0f9d58;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 500;
    white-space: nowrap;
  }

  .custom-cart-item__savings-badge svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .custom-cart-item__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .custom-cart-item__quantity {
    display: flex;
    align-items: center;
  }

  .custom-cart-item__quantity .custom-quantity-selector,
  .custom-cart-item__quantity .quantity-selector {
    display: flex;
    align-items: center;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    overflow: hidden;
    height: 35px;
    width: fit-content;
    font-size: 12px;
  }

  .custom-cart-item__quantity button {
    width: 100px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 20px;
    font-weight: 400;
    color: #000;
    transition: background 0.2s ease;
  }

  .custom-cart-item__quantity button:hover {
    background: #e8e8e8;
  }

  .custom-cart-item__quantity button:active {
    background: #ddd;
  }

  .custom-cart-item__quantity input {
    width: 100px;
    height: 44px;
    text-align: center;
    border: none;
    border-left: 1px solid #e5e5e5;
    border-right: 1px solid #e5e5e5;
    font-size: 16px;
    font-weight: 500;
    background: transparent;
    color: #000;
  }

  .custom-cart-item__quantity input:focus {
    outline: none;
    background: #fff;
  }

  .custom-cart-item__remove {
    width: 40px;
    height: 40px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .custom-cart-item__remove svg {
    width: 24px;
    height: 24px;
  }

  .custom-cart-item__error {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    padding: 8px;
    background: #fff5f5;
    border: 1px solid #ffebeb;
    border-radius: 4px;
  }

  .custom-cart-item__error.hidden {
    display: none;
  }

  .custom-cart-item__error-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .custom-cart-item__error-icon svg {
    width: 100%;
    height: 100%;
    color: #d32f2f;
  }

  .custom-cart-item__error-text {
    font-size: 12px;
    color: #d32f2f;
    line-height: 1.4;
  }
{% endstylesheet %}
