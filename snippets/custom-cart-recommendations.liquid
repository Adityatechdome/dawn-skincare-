{%- comment -%}
  Custom Cart Recommendations - Product carousel in cart drawer
  Uses product metafields for recommendations, falls back to block settings
  Excludes products already in cart
{%- endcomment -%}

{%- liquid
  assign cart_product_ids = cart.items | map: 'product_id'
  assign recommendations_limit = 6
  assign has_metafield_recommendations = false
  assign recommendation_count = 0
-%}

<div class="custom-cart-recommendations">
  {%- if block == blank -%}
    <p style="padding: 20px; color: #999; font-size: 14px; text-align: center;">
      No recommendation block found. Add a "Product Recommendations" block in the theme customizer.
    </p>
  {%- elsif block.settings.recommended_products == blank -%}
    <p style="padding: 20px; color: #999; font-size: 14px; text-align: center;">
      No products configured. Add products to the "Product Recommendations" block settings.
    </p>
  {%- else -%}
    <div class="custom-cart-recommendations__carousel">
      <button
        class="custom-cart-recommendations__arrow custom-cart-recommendations__arrow--prev"
        aria-label="Previous"
        type="button"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M12.8333 6.99999H1.16663M1.16663 6.99999L6.99996 12.8333M1.16663 6.99999L6.99996 1.16666" stroke="#344054" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <div class="swiper custom-cart-recommendations-swiper">
        <div class="swiper-wrapper">
          {%- comment -%} First, check for combo products {%- endcomment -%}
          {%- for product in block.settings.recommended_products -%}
            {%- if product.metafields.custom.combo_products != blank -%}
              {%- assign combo_component_products = product.metafields.custom.combo_products.value -%}
              {%- assign matching_count = 0 -%}
              {%- assign all_combo_product_ids = '' -%}

              {%- comment -%} Count matching components and collect all IDs {%- endcomment -%}
              {%- for combo_item in combo_component_products -%}
                {%- assign all_combo_product_ids = all_combo_product_ids | append: combo_item.id | append: ',' -%}
                {%- if cart_product_ids contains combo_item.id -%}
                  {%- assign matching_count = matching_count | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}

              {%- comment -%} Remove trailing comma {%- endcomment -%}
              {%- assign all_combo_product_ids = all_combo_product_ids | remove_last: ',' -%}

              {%- comment -%} Show combo if 2+ components are in cart {%- endcomment -%}
              {%- if matching_count >= 2 -%}
                {%- unless cart_product_ids contains product.id -%}
                  {%- assign recommendation_count = recommendation_count | plus: 1 -%}
                  <div class="swiper-slide">
                    {% render 'cart-recommendation-card',
                      product: product,
                      is_combo: true,
                      combo_component_ids: all_combo_product_ids
                    %}
                  </div>
                {%- endunless -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}

          {%- comment -%} Then show regular recommendations {%- endcomment -%}
          {%- for item in cart.items -%}
            {%- if item.product.metafields.custom.recommended_products != blank -%}
              {%- assign metafield_products = item.product.metafields.custom.recommended_products.value -%}
              {%- if metafield_products != blank -%}
                {%- assign has_metafield_recommendations = true -%}
                {%- for product in metafield_products limit: recommendations_limit -%}
                  {%- unless cart_product_ids contains product.id -%}
                    {%- assign recommendation_count = recommendation_count | plus: 1 -%}
                    <div class="swiper-slide">
                      {% render 'cart-recommendation-card', product: product %}
                    </div>
                  {%- endunless -%}
                {%- endfor -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}

          {%- unless has_metafield_recommendations -%}
            {%- for product in block.settings.recommended_products limit: recommendations_limit -%}
              {%- comment -%} Skip combo products (already shown above) {%- endcomment -%}
              {%- if product.metafields.custom.combo_products == blank -%}
                {%- unless cart_product_ids contains product.id -%}
                  {%- assign recommendation_count = recommendation_count | plus: 1 -%}
                  <div class="swiper-slide">
                    {% render 'cart-recommendation-card', product: product %}
                  </div>
                {%- endunless -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endunless -%}
        </div>
      </div>

      <button
        class="custom-cart-recommendations__arrow custom-cart-recommendations__arrow--next"
        aria-label="Next"
        type="button"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M1.16675 6.99999H12.8334M12.8334 6.99999L7.00008 1.16666M12.8334 6.99999L7.00008 12.8333" stroke="#344054" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>
    </div>

    {%- if recommendation_count == 0 -%}
      <p style="padding: 20px; color: #999; font-size: 14px; text-align: center;">
        All recommended products are already in your cart.
      </p>
    {%- endif -%}
  {%- endif -%}
</div>

{% stylesheet %}
  .custom-cart-recommendations {
    padding: 24px 0;
  }

  .custom-cart-recommendations__carousel {
    position: relative;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .custom-cart-recommendations-swiper {
    flex: 1;
    overflow: hidden;
  }

  .custom-cart-recommendations-swiper .swiper-slide {
    height: auto;
  }

  .custom-cart-recommendation {
    background: #f0f0f5;
    border-radius: 16px;
    padding: 12px;
    display: flex;
    gap: 16px;
    align-items: flex-start;
    height: 100%;
  }

  .custom-cart-recommendation__image {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
  }

  .custom-cart-recommendation__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .custom-cart-recommendation__details {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 0;
  }

  .custom-cart-recommendation__title {
    font-size: 16px;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
    color: #000;
  }

  .custom-cart-recommendation__title a {
    color: #000;
    text-decoration: none;
  }

  .custom-cart-recommendation__price-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .custom-cart-recommendation__price {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .custom-cart-recommendation__price-sale {
    font-size: 16px;
    font-weight: 700;
    color: #000;
  }

  .custom-cart-recommendation__price-regular {
    font-size: 16px;
    font-weight: 700;
    color: #000;
  }

  .custom-cart-recommendation__price-compare {
    font-size: 16px;
    color: #999;
    text-decoration: line-through;
  }

  .custom-cart-recommendation__discount {
    font-size: 10px;
    background-color: rgb(220, 250, 230);
    color: #0f9d58;
    font-weight: 600;
    padding: 5px;
    border-radius: 5px;
  }

  .custom-cart-recommendation__actions {
    display: flex;
    align-items: end;
    gap: 12px;
  }

  .custom-cart-recommendation__variant {
    display: flex;
    align-items: start;
    flex-direction: column;
    gap: 8px;
  }

  .custom-cart-recommendation__variant-label {
    font-size: 14px;
    color: #666;
  }

  .custom-cart-recommendation__variant-select {
    font-size: 14px;
    padding: 8px 32px 8px 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    background: #fff;
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%23000' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 10px center;
    min-width: 80px;
  }

  .custom-cart-recommendation__variant-select:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .custom-cart-recommendation__add-btn {
    padding: 10px 20px;
    background: #7c3aed;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s ease;
    white-space: nowrap;
  }

  .custom-cart-recommendation__add-btn:hover {
    background: #6d28d9;
  }

  .custom-cart-recommendation__add-btn:disabled {
    background: #ccc;
    cursor: not-allowed;
  }

  .custom-cart-recommendations__arrow {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .custom-cart-recommendations__arrow:hover {
    background: #f5f5f5;
  }

  .custom-cart-recommendations__arrow.swiper-button-disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .custom-cart-recommendations__arrow svg {
    width: 14px;
    height: 14px;
  }

  .combo-badge {
    display: inline-block;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 4px 8px;
    border-radius: 4px;
    margin-right: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 2px 4px rgba(102, 126, 234, 0.3);
  }

  @media (max-width: 600px) {
    .custom-cart-drawer__recommendations {
      padding: 0;
    }

    .custom-cart-recommendations__carousel {
      gap: 8px;
    }

    .custom-cart-recommendation, .custom-cart-recommendation__price-row {
      gap: 6px;
    }

    .custom-cart-recommendation__price-sale,
    .custom-cart-recommendation__price-regular {
      font-size: 14px;
    }

    .custom-cart-recommendation__price-compare {
      font-size: 14px;
    }

    .custom-cart-recommendation__add-btn {
      font-size: 12px;
      padding: 10px;
    }

    .custom-cart-recommendation__variant-select {
      padding: 6px 24px 6px 6px;
      font-size: 12px;
    }
  }
{% endstylesheet %}

